{% extends 'base.html.twig' %}

{% block title %}Login - Sports Management{% endblock %}

{% block body %}
<div class="login-container">
    <div class="col-md-5 col-lg-4">
        <div class="card card-custom">
            <div class="card-body p-5">
                <h2 class="text-center mb-4" style="color: var(--primary-green);">Login</h2>
                
                {% if error %}
                    <div class="alert alert-error mb-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}
                
                <form method="post">
                    <div class="mb-3">
                        <label for="username" class="form-label">Email</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
                    </div>
                    
                    <div class="mb-4">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                    </div>
                    
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    
                    <div class="d-grid">
                        <button class="btn btn-primary-custom btn-lg" type="submit">Sign In</button>
                    </div>
                    
                    <div class="text-center mt-3">
                        <p>Don't have an account? <a href="{{ path('app_register') }}" style="color: var(--primary-green);">Register here</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}