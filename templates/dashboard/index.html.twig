function closeChatbot() {
    document.getElementById('chatbotWidget').classList.remove('active');
}

function sendWidgetMessage(event) {
    event.preventDefault();

    const input = document.getElementById('widgetInput');
    const message = input.value.trim();

    if (!message || isWidgetLoading) return;

    // Add user message
    addWidgetMessage(message, 'user');

    // Clear input
    input.value = '';

    // Send to backend
    isWidgetLoading = true;
    document.getElementById('widgetSendBtn').disabled = true;

    fetch('{{ path('api_chatbot_message') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ message: message })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            addWidgetMessage(data.response, 'bot');
        } else {
            addWidgetMessage('Error: ' + data.message, 'bot');
        }
    })
    .catch(error => {
        addWidgetMessage('Connection error: ' + error.message, 'bot');
    })
    .finally(() => {
        isWidgetLoading = false;
        document.getElementById('widgetSendBtn').disabled = false;
        document.getElementById('widgetInput').focus();
    });
}

function addWidgetMessage(text, sender) {
    const messagesContainer = document.getElementById('widgetMessages');
    const messageDiv = document.createElement('div');
    messageDiv.className = `widget-message ${sender === 'user' ? 'user-message' : 'bot-message'}`;
    
    // Format text with line breaks
    const lines = text.split('\n');
    lines.forEach((line, index) => {
        const p = document.createElement('p');
        p.textContent = line;
        messageDiv.appendChild(p);
    });

    messagesContainer.appendChild(messageDiv);

    // Scroll to bottom
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

// Allow Enter to send in widget
document.addEventListener('DOMContentLoaded', function() {
    const widgetInput = document.getElementById('widgetInput');
    if (widgetInput) {
        widgetInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendWidgetMessage(new Event('submit'));
            }
        });
    }
});
