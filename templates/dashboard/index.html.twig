{% extends 'base.html.twig' %}

{% block title %}Dashboard - Sports Management{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-lg-3 mb-4">
            <div class="sidebar p-4 rounded">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                        <span style="color: var(--primary-green); font-size: 2.5rem; font-weight: bold;">
                            {{ user.name|first|upper }}
                        </span>
                    </div>
                    <h4 class="mt-3">{{ user.name }}</h4>
                    <span class="role-badge">{{ user.roleType|capitalize }}</span>
                    <p class="text-muted mt-2">{{ user.email }}</p>
                </div>
                
                <hr>
                
                <nav class="nav flex-column">
                    <a class="nav-link active" href="#" style="color: var(--primary-green);">
                        <strong>Dashboard</strong>
                    </a>
                    <a class="nav-link" href="#">My Profile</a>
                    <a class="nav-link" href="#">Settings</a>
                    {% if user.roleType == 'admin' %}
                        <a class="nav-link" href="#">Admin Panel</a>
                    {% elseif user.roleType == 'coach' %}
                        <a class="nav-link" href="#">My Athletes</a>
                        <a class="nav-link" href="#">Training Plans</a>
                    {% elseif user.roleType == 'athlete' %}
                        <a class="nav-link" href="#">My Progress</a>
                        <a class="nav-link" href="#">Workouts</a>
                    {% endif %}
                </nav>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="col-lg-9">
            <div class="row">
                <div class="col-12">
                    <h2 class="mb-4" style="color: var(--primary-green);">Welcome to Your Dashboard</h2>
                </div>
                
                <!-- User Details Card -->
                <div class="col-md-6 mb-4">
                    <div class="card card-custom h-100">
                        <div class="card-body">
                            <h5 class="card-title" style="color: var(--primary-green);">Personal Information</h5>
                            <hr>
                            <div class="mb-3">
                                <strong>Full Name:</strong>
                                <p class="text-muted">{{ user.name }}</p>
                            </div>
                            <div class="mb-3">
                                <strong>Email Address:</strong>
                                <p class="text-muted">{{ user.email }}</p>
                            </div>
                            <div class="mb-3">
                                <strong>Role:</strong>
                                <p class="text-muted">{{ user.roleType|capitalize }}</p>
                            </div>
                            <div class="mb-3">
                                <strong>Account Created:</strong>
                                <p class="text-muted">{{ 'now'|date('Y-m-d') }}</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Role-specific Card -->
                <div class="col-md-6 mb-4">
                    <div class="card card-custom h-100">
                        <div class="card-body">
                            <h5 class="card-title" style="color: var(--primary-green);">
                                {% if user.roleType == 'admin' %}
                                    Admin Privileges
                                {% elseif user.roleType == 'coach' %}
                                    Coach Tools
                                {% else %}
                                    Athlete Dashboard
                                {% endif %}
                            </h5>
                            <hr>
                            {% if user.roleType == 'admin' %}
                                <p>As an administrator, you have access to:</p>
                                <ul>
                                    <li>User Management</li>
                                    <li>System Settings</li>
                                    <li>Reports & Analytics</li>
                                    <li>Database Administration</li>
                                </ul>
                                <a href="#" class="btn btn-primary-custom">Go to Admin Panel</a>
                            {% elseif user.roleType == 'coach' %}
                                <p>Welcome, Coach! Manage your team:</p>
                                <ul>
                                    <li>View Athlete Progress</li>
                                    <li>Create Training Plans</li>
                                    <li>Schedule Sessions</li>
                                    <li>Track Performance</li>
                                </ul>
                                <a href="#" class="btn btn-primary-custom">Manage Athletes</a>
                            {% else %}
                                <p>Track your athletic journey:</p>
                                <ul>
                                    <li>View Your Progress</li>
                                    <li>Access Workout Plans</li>
                                    <li>Track Performance Metrics</li>
                                    <li>Connect with Coaches</li>
                                </ul>
                                <a href="#" class="btn btn-primary-custom">View My Progress</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Quick Actions -->
                <div class="col-12">
                    <div class="card card-custom">
                        <div class="card-body">
                            <h5 class="card-title" style="color: var(--primary-green);">Quick Actions</h5>
                            <div class="row mt-3">
                                <div class="col-md-3 mb-3">
                                    <a href="#" class="btn btn-outline-primary-custom w-100">
                                        Update Profile
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="#" class="btn btn-outline-primary-custom w-100">
                                        Change Password
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="#" class="btn btn-outline-primary-custom w-100">
                                        View Reports
                                    </a>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <a href="{{ path('app_logout') }}" class="btn btn-outline-danger w-100">
                                        Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}