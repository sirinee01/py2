{% extends 'base.html.twig' %}

{% block title %}Edit User - Admin Panel{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-custom">
                <div class="card-header" style="background-color: var(--primary-green); color: white;">
                    <h5 class="mb-0">Edit User: {{ user.name }}</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name) }}
                            {{ form_errors(form.name) }}
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                        </div>
                        
                        <div class="mb-4">
                            {{ form_label(form.roleType) }}
                            {{ form_widget(form.roleType) }}
                            {{ form_errors(form.roleType) }}
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary-custom">Update User</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}