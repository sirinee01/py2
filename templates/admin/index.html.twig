{% extends 'base.html.twig' %}

{% block title %}Admin Panel - Sports Management{% endblock %}

{% block body %}
<div class="admin-wrapper d-flex" style="min-height: 100vh; width: 100%; margin: 0; padding: 0;">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="sidebar" style="width: 280px; background: linear-gradient(180deg, #1a2e35 0%, #0f1e24 100%); min-height: 100vh; transition: width 0.3s ease; position: fixed; left: 0; top: 0; bottom: 0; z-index: 1000; overflow-y: auto; overflow-x: hidden;">
        <div class="sidebar-header p-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white mb-0" style="font-weight: 600; white-space: nowrap;">
                <span style="color: var(--primary-green);">⚡</span> <span class="sidebar-text">SportsAdmin</span>
            </h3>
            
        </div>
        
        <div class="sidebar-menu p-3">
            <!-- Admin Profile -->
            <div class="admin-profile d-flex align-items-center p-3 mb-4" style="background: rgba(255,255,255,0.05); border-radius: 12px;">
                <div class="avatar me-3" style="width: 48px; height: 48px; background: var(--primary-green); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="fas fa-user-shield text-white" style="font-size: 1.5rem;"></i>
                </div>
                <div class="sidebar-text" style="overflow: hidden;">
                    <h6 class="text-white mb-1" style="white-space: nowrap;">{{ app.user.name|default('Admin User') }}</h6>
                    <p class="text-white-50 small mb-0" style="white-space: nowrap;">{{ app.user.email|default('admin@sports.com') }}</p>
                </div>
            </div>
            
            <!-- Navigation Menu -->
            <nav class="nav flex-column">
    <a href="{{ path('app_admin') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
        <i class="fas fa-tachometer-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
        <span class="sidebar-text">Dashboard</span>
    </a>
    
    <!-- User Management with dropdown -->
    <div class="nav-item">
        
        <a href="{{ path('app_admin') }}" class="nav-link active d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="background: var(--primary-green); color: white;">            <i class="fas fa-users me-3" style="width: 20px; flex-shrink: 0;"></i>
            <span class="sidebar-text flex-grow-1">Users Management</span>
            <i class="fas fa-chevron-down sidebar-text" id="userMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
        </a>
        <!-- Submenu -->
        <div class="user-submenu" id="userSubmenu" style="display: none; margin-left: 2.5rem; margin-bottom: 0.5rem;">
            <a href="{{ path('app_admin') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                <i class="fas fa-users me-2" style="width: 16px; font-size: 0.8rem;"></i>
                <span class="sidebar-text">All Users</span>
            </a>
            
            <a href="{{ path('app_admin') }}?role=athlete" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                <i class="fas fa-running me-2" style="width: 16px;"></i>
                <span class="sidebar-text">Athletes</span>
                <span class="badge ms-auto" style="background: var(--primary-green); font-size: 0.7rem;">{{ stats.athletes }}</span>
            </a>
            
            <a href="{{ path('app_admin') }}?role=coach" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                <i class="fas fa-chalkboard-teacher me-2" style="width: 16px;"></i>
                <span class="sidebar-text">Coaches</span>
                <span class="badge ms-auto" style="background: var(--primary-green); font-size: 0.7rem;">{{ stats.coaches }}</span>
            </a>
            
            <a href="{{ path('app_admin') }}?role=admin" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                <i class="fas fa-user-cog me-2" style="width: 16px;"></i>
                <span class="sidebar-text">Admins</span>
                <span class="badge ms-auto" style="background: var(--primary-green); font-size: 0.7rem;">{{ stats.admins }}</span>
            </a>
        </div>
    </div>
    <a href="{{ path('app_admin_competitions') }} " class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
            <i class="fas fa-trophy "></i> 
            <span class="sidebar-text flex-grow-1 ps-3">Competitions</span>
    </a>

    <a href="" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
            <i class="fas fa-map"></i>
            <span class="sidebar-text flex-grow-1 ps-3">Nutrition Plans</span>
    </a>

    <a href="" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
        <i class="fas fa-bacon "></i>
        <span class="sidebar-text flex-grow-1 ps-3">Meals</span>
    </a>
    
    <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">
    
    <a href="{{ path('app_logout') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,0,0,0.2)'; this.style.color='#ff6b6b';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
        <i class="fas fa-sign-out-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
        <span class="sidebar-text">Logout</span>
    </a>
</nav>
            <div class="btn btn-sm text-white d-flex justify-content-end ">
            <button id="sidebarToggle" class="btn btn-sm text-white d-flex justify-content-end" style="background: transparent; border: none; font-size: 1.2rem;">
                <i class="fas fa-chevron-left" id="toggleIcon"></i>
            </button>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main" id="mainContent" style="margin-left: 280px; width: calc(100% - 280px); background: #f8f9fa; min-height: 100vh;">
    
    <!-- Content Area -->
    <div class="content-area p-4">
        
        <!-- FLASH MESSAGES - Add this block here -->
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px; border-left: 4px solid {% if type == 'success' %}var(--primary-green){% elseif type == 'error' %}#dc3545{% else %}#0dcaf0{% endif %};">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            {% if type == 'success' %}
                                <i class="fas fa-check-circle" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                            {% elseif type == 'error' %}
                                <i class="fas fa-exclamation-circle" style="color: #dc3545; font-size: 1.5rem;"></i>
                            {% else %}
                                <i class="fas fa-info-circle" style="color: #0dcaf0; font-size: 1.5rem;"></i>
                            {% endif %}
                        </div>
                        <div class="flex-grow-1">
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
        <!-- Content Area -->
        <div class="content-area p-4">
        <!-- Breadcrumbs -->
