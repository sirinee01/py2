{% extends 'base.html.twig' %}

{% block title %}Admin Panel - Sports Management{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4" style="color: var(--primary-green);">Admin Panel</h1>
            
            <!-- Statistics Cards -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Total Users</h5>
                            <h2 style="color: var(--primary-green);">{{ stats.totalUsers }}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Athletes</h5>
                            <h2 style="color: var(--primary-green);">{{ stats.athletes }}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Coaches</h5>
                            <h2 style="color: var(--primary-green);">{{ stats.coaches }}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Admins</h5>
                            <h2 style="color: var(--primary-green);">{{ stats.admins }}</h2>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Users Table -->
            <div class="card card-custom">
                <div class="card-header" style="background-color: var(--primary-green); color: white;">
                    <h5 class="mb-0">User Management</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in users %}
                                <tr>
                                    <td>{{ user.id }}</td>
                                    <td>{{ user.name }}</td>
                                    <td>{{ user.email }}</td>
                                    <td>
                                        <span class="role-badge">{{ user.roleType|capitalize }}</span>
                                    </td>
                                    <td>{{ user.createdAt|date('Y-m-d') }}</td>
                                    <td>
                                        <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                        <a href="{{ path('app_admin_user_delete', {'id': user.id}) }}" 
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Are you sure you want to delete this user?')">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="6" class="text-center">No users found</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}