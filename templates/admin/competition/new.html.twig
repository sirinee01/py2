{% extends 'base.html.twig' %}

{% block title %}Create Competition - Admin Panel{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card card-custom">
                <div class="card-header">
                    <h2 class="h4 mb-0">Create New Competition</h2>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger">{{ form_errors(form.name) }}</div>
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.maxParticipants) }}
                            {{ form_widget(form.maxParticipants, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger">{{ form_errors(form.maxParticipants) }}</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                        <div class="text-danger">{{ form_errors(form.description) }}</div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.location) }}
                        {{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger">{{ form_errors(form.location) }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.startDate) }}
                            {{ form_widget(form.startDate, {'attr': {'class': 'form-control datepicker'}}) }}
                            <div class="text-danger">{{ form_errors(form.startDate) }}</div>
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.endDate) }}
                            {{ form_widget(form.endDate, {'attr': {'class': 'form-control datepicker'}}) }}
                            <div class="text-danger">{{ form_errors(form.endDate) }}</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.imageFile) }}
                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                        <small class="text-muted">Recommended size: 800x400px. Max size: 2MB.</small>
                        <div class="text-danger">{{ form_errors(form.imageFile) }}</div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.status) }}
                        {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger">{{ form_errors(form.status) }}</div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('app_admin_competitions') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="fas fa-save"></i> Create Competition
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        flatpickr(".datepicker", {
            enableTime: true,
            dateFormat: "Y-m-d H:i",
            minDate: "today"
        });
        
        const imageFileInput = document.querySelector('#competition_imageFile');
        if (imageFileInput) {
            imageFileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const existingPreview = document.querySelector('.image-preview');
                        if (existingPreview) {
                            existingPreview.remove();
                        }
                        
                        const preview = document.createElement('div');
                        preview.className = 'image-preview mt-2';
                        preview.innerHTML = `
                            <img src="${e.target.result}" 
                                 class="img-fluid rounded" 
                                 style="max-height: 200px; width: auto;">
                        `;
                        imageFileInput.parentNode.appendChild(preview);
                    }
                    reader.readAsDataURL(file);
                }
            });
        }
    });
</script>
{% endblock %}