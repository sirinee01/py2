{% extends 'base.html.twig' %}

{% block title %}Create Competition - Admin Panel{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
<style>
    .flatpickr-calendar {
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border: none;
    }
    .flatpickr-day.selected {
        background: var(--primary-green);
        border-color: var(--primary-green);
    }
    .flatpickr-day.selected:hover {
        background: #059669;
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-wrapper d-flex" style="min-height: 100vh; width: 100%; margin: 0; padding: 0;">
    <!-- Sidebar (Same as admin panel) -->
    <aside class="admin-sidebar" id="sidebar" style="width: 280px; background: linear-gradient(180deg, #1a2e35 0%, #0f1e24 100%); min-height: 100vh; transition: width 0.3s ease; position: fixed; left: 0; top: 0; bottom: 0; z-index: 1000; overflow-y: auto; overflow-x: hidden;">
        <div class="sidebar-header p-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white mb-0" style="font-weight: 600; white-space: nowrap;">
                <span style="color: var(--primary-green);">⚡</span> <span class="sidebar-text">SportsAdmin</span>
            </h3>
        </div>
        
        <div class="sidebar-menu p-3">
            <!-- Admin Profile -->
            <div class="admin-profile d-flex align-items-center p-3 mb-4" style="background: rgba(255,255,255,0.05); border-radius: 12px;">
                <div class="avatar me-3" style="width: 48px; height: 48px; background: var(--primary-green); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="fas fa-user-shield text-white" style="font-size: 1.5rem;"></i>
                </div>
                <div class="sidebar-text" style="overflow: hidden;">
                    <h6 class="text-white mb-1" style="white-space: nowrap;">{{ app.user.name|default('Admin User') }}</h6>
                    <p class="text-white-50 small mb-0" style="white-space: nowrap;">{{ app.user.email|default('admin@sports.com') }}</p>
                </div>
            </div>
            
            <!-- Navigation Menu -->
            <nav class="nav flex-column">
                <a href="{{ path('app_admin') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-tachometer-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                
                <!-- User Management with dropdown -->
                <div class="nav-item">
                    <a href="{{ path('app_admin') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8);" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">            
                        <i class="fas fa-users me-3" style="width: 20px; flex-shrink: 0;"></i>
                        <span class="sidebar-text flex-grow-1">Users Management</span>
                        <i class="fas fa-chevron-down sidebar-text" id="userMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                    </a>
                    <!-- Submenu -->
                    <div class="user-submenu" id="userSubmenu" style="display: none; margin-left: 2.5rem; margin-bottom: 0.5rem;">
                        <a href="{{ path('app_admin') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-users me-2" style="width: 16px; font-size: 0.8rem;"></i>
                            <span class="sidebar-text">All Users</span>
                        </a>
                        <a href="{{ path('app_admin') }}?role=athlete" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-running me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Athletes</span>
                        </a>
                        <a href="{{ path('app_admin') }}?role=coach" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-chalkboard-teacher me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Coaches</span>
                        </a>
                        <a href="{{ path('app_admin') }}?role=admin" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-user-cog me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Admins</span>
                        </a>
                    </div>
                </div>

                <a href="{{ path('app_admin_competitions') }}" class="nav-link active d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="background: var(--primary-green); color: white;">
                    <i class="fas fa-trophy me-3"></i> 
                    <span class="sidebar-text">Competitions</span>
                </a>

                <a href="#" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-utensils me-3"></i>
                    <span class="sidebar-text">Nutrition Plans</span>
                </a>

                <a href="#" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-bacon me-3"></i>
                    <span class="sidebar-text">Meals</span>
                </a>
                
                <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">
                
                <a href="{{ path('app_logout') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,0,0,0.2)'; this.style.color='#ff6b6b';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-sign-out-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Logout</span>
                </a>
            </nav>
            
            <div class="btn btn-sm text-white d-flex justify-content-end">
                <button id="sidebarToggle" class="btn btn-sm text-white d-flex justify-content-end" style="background: transparent; border: none; font-size: 1.2rem;">
                    <i class="fas fa-chevron-left" id="toggleIcon"></i>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main" id="mainContent" style="margin-left: 280px; width: calc(100% - 280px); background: #f8f9fa; min-height: 100vh; transition: margin-left 0.3s ease, width 0.3s ease;">
        
        <!-- Content Area -->
        <div class="content-area p-4">
            
            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px; border-left: 4px solid {% if type == 'success' %}var(--primary-green){% elseif type == 'error' %}#dc3545{% else %}#0dcaf0{% endif %};">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                {% if type == 'success' %}
                                    <i class="fas fa-check-circle" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                {% elseif type == 'error' %}
                                    <i class="fas fa-exclamation-circle" style="color: #dc3545; font-size: 1.5rem;"></i>
                                {% else %}
                                    <i class="fas fa-info-circle" style="color: #0dcaf0; font-size: 1.5rem;"></i>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1">
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin') }}" style="color: var(--primary-green); text-decoration: none;">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_competitions') }}" style="color: var(--primary-green); text-decoration: none;">Competitions</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Create Competition</li>
                </ol>
            </nav>
            
            <!-- Create Competition Card -->
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                        <div class="card-header bg-white border-0 p-4">
                            <div class="d-flex align-items-center">
                                <div class="icon-circle me-3" style="width: 60px; height: 60px; background: rgba(16, 185, 129, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-trophy" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1" style="color: var(--primary-green);">Create New Competition</h4>
                                    <p class="text-muted small mb-0">Fill in the details below to create a new competition</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="card-body p-4">
                            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                            
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_label(form.name, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0" style="background: white;">
                                            <i class="fas fa-trophy" style="color: var(--primary-green);"></i>
                                        </span>
                                        {{ form_widget(form.name, {'attr': {
                                            'class': 'form-control border-0 py-3' ~ (form.name.vars.errors|length ? ' is-invalid' : ''),
                                            'placeholder': 'Enter competition name',
                                            'style': 'background: #f8f9fa;'
                                        }}) }}
                                    </div>
                                    {% if form.name.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.name.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-6 mb-4">
                                    {{ form_label(form.maxParticipants, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0" style="background: white;">
                                            <i class="fas fa-users" style="color: var(--primary-green);"></i>
                                        </span>
                                        {{ form_widget(form.maxParticipants, {'attr': {
                                            'class': 'form-control border-0 py-3' ~ (form.maxParticipants.vars.errors|length ? ' is-invalid' : ''),
                                            'placeholder': 'Maximum participants',
                                            'style': 'background: #f8f9fa;'
                                        }}) }}
                                    </div>
                                    {% if form.maxParticipants.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.maxParticipants.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="mb-4">
                                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                    <span class="input-group-text bg-white border-0" style="background: white; align-items: flex-start;">
                                        <i class="fas fa-align-left" style="color: var(--primary-green);"></i>
                                    </span>
                                    {{ form_widget(form.description, {'attr': {
                                        'class': 'form-control border-0 py-3' ~ (form.description.vars.errors|length ? ' is-invalid' : ''),
                                        'placeholder': 'Enter competition description',
                                        'rows': 4,
                                        'style': 'background: #f8f9fa;'
                                    }}) }}
                                </div>
                                {% if form.description.vars.errors|length %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.description.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mb-4">
                                {{ form_label(form.location, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                    <span class="input-group-text bg-white border-0" style="background: white;">
                                        <i class="fas fa-map-marker-alt" style="color: var(--primary-green);"></i>
                                    </span>
                                    {{ form_widget(form.location, {'attr': {
                                        'class': 'form-control border-0 py-3' ~ (form.location.vars.errors|length ? ' is-invalid' : ''),
                                        'placeholder': 'Enter competition location',
                                        'style': 'background: #f8f9fa;'
                                    }}) }}
                                </div>
                                {% if form.location.vars.errors|length %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.location.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    {{ form_label(form.startDate, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0" style="background: white;">
                                            <i class="fas fa-calendar-alt" style="color: var(--primary-green);"></i>
                                        </span>
                                        {{ form_widget(form.startDate, {'attr': {
                                            'class': 'form-control border-0 py-3 datepicker' ~ (form.startDate.vars.errors|length ? ' is-invalid' : ''),
                                            'placeholder': 'Select start date',
                                            'style': 'background: #f8f9fa;'
                                        }}) }}
                                    </div>
                                    {% if form.startDate.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.startDate.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-6 mb-4">
                                    {{ form_label(form.endDate, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0" style="background: white;">
                                            <i class="fas fa-calendar-check" style="color: var(--primary-green);"></i>
                                        </span>
                                        {{ form_widget(form.endDate, {'attr': {
                                            'class': 'form-control border-0 py-3 datepicker' ~ (form.endDate.vars.errors|length ? ' is-invalid' : ''),
                                            'placeholder': 'Select end date',
                                            'style': 'background: #f8f9fa;'
                                        }}) }}
                                    </div>
                                    {% if form.endDate.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.endDate.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="mb-4">
                                {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                <div class="upload-area p-4 text-center" style="border: 2px dashed #dee2e6; border-radius: 12px; background: #f8f9fa; cursor: pointer;" onclick="document.getElementById('{{ form.imageFile.vars.id }}').click();">
                                    <i class="fas fa-cloud-upload-alt fa-3x mb-3" style="color: var(--primary-green);"></i>
                                    <p class="mb-2"><strong>Click to upload</strong> or drag and drop</p>
                                    <p class="text-muted small mb-0">PNG, JPG, GIF up to 2MB (800x400px recommended)</p>
                                </div>
                                {{ form_widget(form.imageFile, {'attr': {
                                    'class': 'd-none',
                                    'accept': 'image/*'
                                }}) }}
                                <div id="imagePreview" class="mt-3 text-center" style="display: none;">
                                    <img src="" class="img-fluid rounded shadow-sm" style="max-height: 200px; width: auto;">
                                    <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="removeImage()">
                                        <i class="fas fa-times"></i> Remove
                                    </button>
                                </div>
                                <small class="text-muted">Recommended size: 800x400px. Max size: 2MB.</small>
                                {% if form.imageFile.vars.errors|length %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.imageFile.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mb-4">
                                {{ form_label(form.status, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                    <span class="input-group-text bg-white border-0" style="background: white;">
                                        <i class="fas fa-flag" style="color: var(--primary-green);"></i>
                                    </span>
                                    {{ form_widget(form.status, {'attr': {
                                        'class': 'form-select border-0 py-3' ~ (form.status.vars.errors|length ? ' is-invalid' : ''),
                                        'style': 'background: #f8f9fa;'
                                    }}) }}
                                </div>
                                {% if form.status.vars.errors|length %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.status.vars.errors %}
                                            {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                <a href="{{ path('app_admin_competitions') }}" class="btn btn-link text-decoration-none" style="color: #6c757d;">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Back to Competitions
                                </a>
                                <button type="submit" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                    <i class="fas fa-save me-2"></i>
                                    Create Competition
                                </button>
                            </div>
                            
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<style>
:root {
    --primary-green: #10b981;
}

body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
}

.admin-wrapper {
    position: relative;
}

.admin-sidebar {
    box-shadow: 4px 0 10px rgba(0,0,0,0.1);
}

.admin-sidebar.collapsed {
    width: 80px !important;
}

.admin-sidebar.collapsed .sidebar-text {
    display: none;
}

.admin-sidebar.collapsed .nav-link {
    justify-content: center;
    padding: 12px !important;
}

.admin-sidebar.collapsed .nav-link i {
    margin-right: 0 !important;
}

.admin-sidebar.collapsed .badge {
    display: none;
}

.admin-sidebar.collapsed .admin-profile {
    justify-content: center;
}

.admin-sidebar.collapsed .admin-profile .avatar {
    margin-right: 0 !important;
}

#mainContent.expanded {
    margin-left: 80px !important;
    width: calc(100% - 80px) !important;
}

.nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    white-space: nowrap;
}

.nav-link.active {
    box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
}

.upload-area {
    transition: all 0.3s ease;
}

.upload-area:hover {
    border-color: var(--primary-green) !important;
    background: rgba(16, 185, 129, 0.05) !important;
}

/* Form styling */
.form-control:focus, .form-select:focus {
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.25);
    border-color: var(--primary-green);
}

/* Hide navbar from base template if any */
.navbar, header, .top-navbar {
    display: none !important;
}

/* Custom scrollbar */
.admin-main::-webkit-scrollbar {
    width: 8px;
}

.admin-main::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.admin-main::-webkit-scrollbar-thumb {
    background: var(--primary-green);
    border-radius: 4px;
}

.admin-main::-webkit-scrollbar-thumb:hover {
    background: #059669;
}
</style>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- Flatpickr JS -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
// Sidebar toggle functionality
document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    const toggleIcon = document.getElementById('toggleIcon');
    
    // Check local storage for sidebar state
    const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        mainContent.classList.add('expanded');
        toggleIcon.classList.remove('fa-chevron-left');
        toggleIcon.classList.add('fa-chevron-right');
    }
    
    toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.classList.remove('fa-chevron-left');
            toggleIcon.classList.add('fa-chevron-right');
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.classList.remove('fa-chevron-right');
            toggleIcon.classList.add('fa-chevron-left');
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    });

    // User submenu toggle
    const userMenuLink = document.querySelector('.nav-link[href*="app_admin"] .fa-chevron-down')?.parentElement;
    if (userMenuLink) {
        userMenuLink.addEventListener('click', function(e) {
            e.preventDefault();
            const submenu = document.getElementById('userSubmenu');
            const arrow = document.getElementById('userMenuArrow');
            
            if (submenu.style.display === 'none' || !submenu.style.display) {
                submenu.style.display = 'block';
                arrow.style.transform = 'rotate(180deg)';
            } else {
                submenu.style.display = 'none';
                arrow.style.transform = 'rotate(0deg)';
            }
        });
    }

    // Initialize flatpickr
    flatpickr(".datepicker", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        minDate: "today",
        time_24hr: true,
        theme: "material_green"
    });
    
    // Image upload preview
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const uploadArea = document.querySelector('.upload-area');
    
    imageInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const previewImg = imagePreview.querySelector('img');
                previewImg.src = e.target.result;
                imagePreview.style.display = 'block';
                uploadArea.style.display = 'none';
            }
            reader.readAsDataURL(file);
        }
    });
});

function removeImage() {
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const uploadArea = document.querySelector('.upload-area');
    
    imageInput.value = '';
    imagePreview.style.display = 'none';
    uploadArea.style.display = 'block';
}
</script>
{% endblock %}