{% extends 'base.html.twig' %}

{% block title %}Register - Sports Management{% endblock %}

{% block body %}
<div class="login-container">
    <div class="col-md-6 col-lg-5">
        <div class="card card-custom">
            <div class="card-body p-5">
                <h2 class="text-center mb-4" style="color: var(--primary-green);">Create Account</h2>
                
                {{ form_start(registrationForm) }}
                    <div class="mb-3">
                        {{ form_label(registrationForm.name) }}
                        {{ form_widget(registrationForm.name) }}
                        {{ form_errors(registrationForm.name) }}
                    </div>
                    
                    <div class="mb-3">
                        {{ form_label(registrationForm.email) }}
                        {{ form_widget(registrationForm.email) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>
                    
                    <div class="mb-3">
                        {{ form_label(registrationForm.roleType) }}
                        {{ form_widget(registrationForm.roleType) }}
                        {{ form_errors(registrationForm.roleType) }}
                    </div>
                    
                    <div class="mb-4">
                        {{ form_label(registrationForm.plainPassword) }}
                        {{ form_widget(registrationForm.plainPassword) }}
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary-custom btn-lg">Register</button>
                    </div>
                    
                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="{{ path('app_login') }}" style="color: var(--primary-green);">Login here</a></p>
                    </div>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}