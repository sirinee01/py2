                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-4 mb-4">
                                        {{ form_label(form.protein, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
