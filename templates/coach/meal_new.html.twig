                                        {% if form.fat.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.fat.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="upload-area p-4 text-center" style="border: 2px dashed #dee2e6; border-radius: 12px; background: #f8f9fa; cursor: pointer;" onclick="document.getElementById('{{ form.imageFile.vars.id }}').click();">
