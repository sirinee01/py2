<style>
:root {
    --primary-green: #10b981;
}

body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
}

.admin-wrapper {
    position: relative;
}

.admin-sidebar {
    box-shadow: 4px 0 10px rgba(0,0,0,0.1);
}

.admin-sidebar.collapsed {
    width: 80px !important;
}

.admin-sidebar.collapsed .sidebar-text {
    display: none;
}

.admin-sidebar.collapsed .nav-link {
    justify-content: center;
    padding: 12px !important;
}

.admin-sidebar.collapsed .nav-link i {
    margin-right: 0 !important;
}

.admin-sidebar.collapsed .badge {
    display: none;
}

.admin-sidebar.collapsed .admin-profile {
    justify-content: center;
}

.admin-sidebar.collapsed .admin-profile .avatar {
    margin-right: 0 !important;
}

#mainContent.expanded {
    margin-left: 80px !important;
    width: calc(100% - 80px) !important;
}

.nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    white-space: nowrap;
}

.nav-link.active {
    box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
}

.upload-area {
    transition: all 0.3s ease;
}

.upload-area:hover {
    border-color: var(--primary-green) !important;
    background: rgba(16, 185, 129, 0.05) !important;
}

/* Form styling */
.form-control:focus, .form-select:focus {
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.25);
    border-color: var(--primary-green);
}

/* Hide navbar from base template if any */
.navbar, header, .top-navbar {
    display: none !important;
}

/* Custom scrollbar */
.admin-main::-webkit-scrollbar {
    width: 8px;
}

.admin-main::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.admin-main::-webkit-scrollbar-thumb {
    background: var(--primary-green);
    border-radius: 4px;
}

.admin-main::-webkit-scrollbar-thumb:hover {
    background: #059669;
}
</style>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
// Sidebar toggle functionality
document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    const toggleIcon = document.getElementById('toggleIcon');
    
    // Check local storage for sidebar state
    const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        mainContent.classList.add('expanded');
        toggleIcon.classList.remove('fa-chevron-left');
        toggleIcon.classList.add('fa-chevron-right');
    }
    
    toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.classList.remove('fa-chevron-left');
            toggleIcon.classList.add('fa-chevron-right');
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.classList.remove('fa-chevron-right');
            toggleIcon.classList.add('fa-chevron-left');
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    });

    // Live preview functionality
    const caloriesInput = document.getElementById('{{ form.calories.vars.id }}');
    const proteinInput = document.getElementById('{{ form.protein.vars.id }}');
    const carbsInput = document.getElementById('{{ form.carbs.vars.id }}');
    const fatInput = document.getElementById('{{ form.fat.vars.id }}');
    
    const previewCalories = document.getElementById('previewCalories');
    const previewProtein = document.getElementById('previewProtein');
    const previewCarbs = document.getElementById('previewCarbs');
    const previewFat = document.getElementById('previewFat');
    
    if (caloriesInput) {
        caloriesInput.addEventListener('input', function() {
            previewCalories.textContent = this.value || '0';
        });
    }
    
    if (proteinInput) {
        proteinInput.addEventListener('input', function() {
            previewProtein.textContent = (this.value || '0') + 'g';
        });
    }
    
    if (carbsInput) {
        carbsInput.addEventListener('input', function() {
            previewCarbs.textContent = (this.value || '0') + 'g';
        });
    }
    
    if (fatInput) {
        fatInput.addEventListener('input', function() {
            previewFat.textContent = (this.value || '0') + 'g';
        });
    }

    // Image upload preview
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const uploadArea = document.querySelector('.upload-area');
    
    if (imageInput) {
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const previewImg = imagePreview.querySelector('img');
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                    uploadArea.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        });
    }
});

function toggleSubmenu(event, submenuId) {
    event.preventDefault();
    const submenu = document.getElementById(submenuId);
    const arrow = submenuId === 'nutritionSubmenu' ? document.getElementById('nutritionMenuArrow') : document.getElementById('mealsMenuArrow');
    
    if (submenu.style.display === 'none' || !submenu.style.display) {
        submenu.style.display = 'block';
        arrow.style.transform = 'rotate(180deg)';
    } else {
        submenu.style.display = 'none';
        arrow.style.transform = 'rotate(0deg)';
    }
}

function removeImage() {
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const uploadArea = document.querySelector('.upload-area');
    
    if (imageInput) {
        imageInput.value = '';
        imagePreview.style.display = 'none';
        uploadArea.style.display = 'block';
    }
}

// Keep meals submenu open on this page
document.addEventListener('DOMContentLoaded', function() {
    const mealsSubmenu = document.getElementById('mealsSubmenu');
    const mealsArrow = document.getElementById('mealsMenuArrow');
    if (mealsSubmenu) {
        mealsSubmenu.style.display = 'block';
        mealsArrow.style.transform = 'rotate(180deg)';
    }
});
</script>
{% endblock %}