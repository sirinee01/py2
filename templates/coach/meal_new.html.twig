                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    <div class="col-md-4 mb-4">
                                        {{ form_label(form.carbs, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-bread-slice" style="color: var(--primary-green);"></i>
