{% extends 'base.html.twig' %}

{% block title %}Coach Dashboard - Sports Management{% endblock %}

{% block body %}
<div class="admin-wrapper d-flex" style="min-height: 100vh; width: 100%; margin: 0; padding: 0;">
    <!-- Sidebar (same as before) -->
    <aside class="admin-sidebar" id="sidebar" style="width: 280px; background: linear-gradient(180deg, #1a2e35 0%, #0f1e24 100%); min-height: 100vh; transition: width 0.3s ease; position: fixed; left: 0; top: 0; bottom: 0; z-index: 1000; overflow-y: auto; overflow-x: hidden;">
        <div class="sidebar-header p-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white mb-0" style="font-weight: 600; white-space: nowrap;">
                <span style="color: var(--primary-green);">⚡</span> <span class="sidebar-text">CoachPanel</span>
            </h3>
        </div>
        
        <div class="sidebar-menu p-3">
            <!-- Coach Profile -->
            <div class="admin-profile d-flex align-items-center p-3 mb-4" style="background: rgba(255,255,255,0.05); border-radius: 12px;">
                <div class="avatar me-3" style="width: 48px; height: 48px; background: var(--primary-green); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="fas fa-chalkboard-teacher text-white" style="font-size: 1.5rem;"></i>
                </div>
                <div class="sidebar-text" style="overflow: hidden;">
                    <h6 class="text-white mb-1" style="white-space: nowrap;">{{ app.user.name|default('Coach') }}</h6>
                    <p class="text-white-50 small mb-0" style="white-space: nowrap;">{{ app.user.email|default('coach@sports.com') }}</p>
                </div>
            </div>
            
            <!-- Navigation Menu -->
            <nav class="nav flex-column">
                <a href="{{ path('app_coach_dashboard') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-tachometer-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                
                <a href="{{ path('app_coach_athletes') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-users me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">My Athletes</span>
                </a>
                
                <!-- Nutrition Plans with dropdown -->
                <div class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8);" onclick="toggleSubmenu(event, 'nutritionSubmenu')" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                        <i class="fas fa-utensils me-3" style="width: 20px; flex-shrink: 0;"></i>
                        <span class="sidebar-text flex-grow-1">Nutrition Plans</span>
                        <i class="fas fa-chevron-down sidebar-text" id="nutritionMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                    </a>
                    <!-- Submenu -->
                    <div class="submenu" id="nutritionSubmenu" style="display: none; margin-left: 2.5rem; margin-bottom: 0.5rem;">
                        <a href="{{ path('app_coach_nutrition_plan_new') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-plus-circle me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Create New Plan</span>
                        </a>
                        <a href="{{ path('app_coach_dashboard') }}#plans" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-list me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">View All Plans</span>
                        </a>
                    </div>
                </div>
                
                <!-- Meals with dropdown -->
                <div class="nav-item">
                    <a href="#" class="nav-link active d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="background: var(--primary-green); color: white;" onclick="toggleSubmenu(event, 'mealsSubmenu')">
                        <i class="fas fa-bacon me-3" style="width: 20px; flex-shrink: 0;"></i>
                        <span class="sidebar-text flex-grow-1">Meals</span>
                        <i class="fas fa-chevron-down sidebar-text" id="mealsMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                    </a>
                    <!-- Submenu -->
                    <div class="submenu" id="mealsSubmenu" style="display: block; margin-left: 2.5rem; margin-bottom: 0.5rem;">
                        <a href="{{ path('app_coach_meal_new') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="background: rgba(255,255,255,0.1); color: white; font-size: 0.9rem;">
                            <i class="fas fa-plus-circle me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Add New Meal</span>
                        </a>
                        <a href="{{ path('app_coach_dashboard') }}#meals" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-list me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">View All Meals</span>
                        </a>
                    </div>
                </div>
                
                <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">
                
                <a href="{{ path('app_logout') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,0,0,0.2)'; this.style.color='#ff6b6b';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-sign-out-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Logout</span>
                </a>
            </nav>
            
            <div class="btn btn-sm text-white d-flex justify-content-end">
                <button id="sidebarToggle" class="btn btn-sm text-white d-flex justify-content-end" style="background: transparent; border: none; font-size: 1.2rem;">
                    <i class="fas fa-chevron-left" id="toggleIcon"></i>
                </button>
            </div>
        </div>
    </aside>


    <!-- Main Content -->
    <main class="admin-main" id="mainContent" style="margin-left: 280px; width: calc(100% - 280px); background: #f8f9fa; min-height: 100vh; transition: margin-left 0.3s ease, width 0.3s ease;">
        
        <!-- Content Area -->
        <div class="content-area p-4">
            
            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px; border-left: 4px solid {% if type == 'success' %}var(--primary-green){% elseif type == 'error' %}#dc3545{% else %}#0dcaf0{% endif %};">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                {% if type == 'success' %}
                                    <i class="fas fa-check-circle" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                {% elseif type == 'error' %}
                                    <i class="fas fa-exclamation-circle" style="color: #dc3545; font-size: 1.5rem;"></i>
                                {% else %}
                                    <i class="fas fa-info-circle" style="color: #0dcaf0; font-size: 1.5rem;"></i>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1">
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_coach_dashboard') }}" style="color: var(--primary-green); text-decoration: none;">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Overview</li>
                </ol>
            </nav>
            
            <!-- Welcome Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1" style="color: #1a2e35;">Welcome back, {{ app.user.name }}!</h2>
                    <p class="text-muted">Here's what's happening with your nutrition plans today.</p>
                </div>
                <div>
                    <span class="badge bg-light text-dark p-3 rounded-3" style="box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <i class="far fa-calendar-alt me-2" style="color: var(--primary-green);"></i>
                        {{ "now"|date('l, F j, Y') }}
                    </span>
                </div>
            </div>
            
            <!-- Statistics Cards -->
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 mb-2">Nutrition Plans</h6>
                                    <h2 class="text-white mb-0" style="font-size: 2.5rem; font-weight: 700;">{{ nutritionPlans|length }}</h2>
                                </div>
                                <div class="icon-circle bg-white bg-opacity-25 rounded-circle p-3">
                                    <i class="fas fa-utensils text-white" style="font-size: 2rem;"></i>
                                </div>
                            </div>
                            <div class="mt-3">
                                <a href="{{ path('app_coach_nutrition_plan_new') }}" class="text-white-50 small text-decoration-none">
                                    <i class="fas fa-plus-circle me-1"></i> Create new plan
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 mb-2">Meals</h6>
                                    <h2 class="text-white mb-0" style="font-size: 2.5rem; font-weight: 700;">{{ meals|length }}</h2>
                                </div>
                                <div class="icon-circle bg-white bg-opacity-25 rounded-circle p-3">
                                    <i class="fas fa-bacon text-white" style="font-size: 2rem;"></i>
                                </div>
                            </div>
                            <div class="mt-3">
                                <a href="{{ path('app_coach_meal_new') }}" class="text-white-50 small text-decoration-none">
                                    <i class="fas fa-plus-circle me-1"></i> Add new meal
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; background: linear-gradient(135deg, #4ac29a 0%, #bdfff3 100%);">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 mb-2">My Athletes</h6>
                                    <h2 class="text-white mb-0" style="font-size: 2.5rem; font-weight: 700;">{{ athletes|length }}</h2>
                                </div>
                                <div class="icon-circle bg-white bg-opacity-25 rounded-circle p-3">
                                    <i class="fas fa-users text-white" style="font-size: 2rem;"></i>
                                </div>
                            </div>
                            <div class="mt-3">
                                <a href="{{ path('app_coach_athletes') }}" class="text-white-50 small text-decoration-none">
                                    <i class="fas fa-arrow-right me-1"></i> Manage athletes
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Nutrition Plans -->
            <div class="row mb-4" id="plans">
                <div class="col-12">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                        <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1" style="color: var(--primary-green);">My Nutrition Plans</h5>
                                <p class="text-muted small mb-0">Manage and track your nutrition plans</p>
                            </div>
                            <div>
                                <a href="{{ path('app_coach_nutrition_plan_new') }}" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                    <i class="fas fa-plus-circle me-2"></i>Create New Plan
                                </a>
                            </div>
                        </div>
                        
                        <div class="card-body p-0">
                            {% if nutritionPlans|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead style="background: #f8f9fa;">
                                            <tr>
                                                <th class="py-3 px-4">Name</th>
                                                <th class="py-3">Description</th>
                                                <th class="py-3">Duration</th>
                                                <th class="py-3">Objective</th>
                                                <th class="py-3">Assigned To</th>
                                                <th class="py-3 px-4">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for plan in nutritionPlans|slice(0, 5) %}
                                            <tr>
                                                <td class="px-4">
                                                    <div class="d-flex align-items-center">
                                                        <div class="avatar-circle me-3" style="width: 40px; height: 40px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                                            {{ plan.name|first|upper }}
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0">{{ plan.name }}</h6>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="text-muted small">{{ plan.description|slice(0, 50) }}{% if plan.description|length > 50 %}...{% endif %}</span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2">
                                                        <i class="fas fa-clock me-2"></i>{{ plan.duration }} days
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="text-muted small">{{ plan.objective|slice(0, 30) }}{% if plan.objective|length > 30 %}...{% endif %}</span>
                                                </td>
                                                <td>
                                                    {% set assignedCount = 0 %}
                                                    {% for athlete in athletes %}
                                                        {% if athlete.assignedNutritionPlan and athlete.assignedNutritionPlan.id == plan.id %}
                                                            {% set assignedCount = assignedCount + 1 %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                                        <i class="fas fa-users me-2"></i>{{ assignedCount }} athletes
                                                    </span>
                                                </td>
                                                <td class="px-4">
                                                    <div class="btn-group" role="group">
                                                        <a href="{{ path('app_coach_nutrition_plan_view', {'id': plan.id}) }}" 
                                                           class="btn btn-sm btn-outline-primary rounded-start-pill px-3"
                                                           title="View Plan">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="{{ path('app_coach_nutrition_plan_edit', {'id': plan.id}) }}" 
                                                           class="btn btn-sm btn-outline-secondary px-3"
                                                           title="Edit Plan">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form method="post" action="{{ path('app_coach_nutrition_plan_delete', {'id': plan.id}) }}" 
                                                              onsubmit="return confirm('Are you sure you want to delete this plan?');"
                                                              style="display: inline;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-end-pill px-3" title="Delete Plan">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                                {% if nutritionPlans|length > 5 %}
                                <div class="p-4 text-center border-top">
                                    <a href="#" class="text-decoration-none" style="color: var(--primary-green);">
                                        View all {{ nutritionPlans|length }} plans <i class="fas fa-arrow-right ms-2"></i>
                                    </a>
                                </div>
                                {% endif %}
                            {% else %}
                                <div class="text-center py-5">
                                    <div class="empty-state">
                                        <i class="fas fa-utensils fa-4x text-muted mb-3"></i>
                                        <h6 class="text-muted">No nutrition plans created yet</h6>
                                        <p class="text-muted small mb-4">Get started by creating your first nutrition plan</p>
                                        <a href="{{ path('app_coach_nutrition_plan_new') }}" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                            <i class="fas fa-plus-circle me-2"></i>Create Your First Plan
                                        </a>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Recent Meals - Now as Table -->
            <div class="row" id="meals">
                <div class="col-12">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                        <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1" style="color: var(--primary-green);">My Meals</h5>
                                <p class="text-muted small mb-0">Manage your meal collection</p>
                            </div>
                            <div>
                                <a href="{{ path('app_coach_meal_new') }}" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                    <i class="fas fa-plus-circle me-2"></i>Add New Meal
                                </a>
                            </div>
                        </div>
                        
                        <div class="card-body p-0">
                            {% if meals|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead style="background: #f8f9fa;">
                                            <tr>
                                                <th class="py-3 px-4">Meal</th>
                                                <th class="py-3">Description</th>
                                                <th class="py-3">Calories</th>
                                                <th class="py-3">Protein</th>
                                                <th class="py-3">Carbs</th>
                                                <th class="py-3">Fat</th>
                                                <th class="py-3">Plans</th>
                                                <th class="py-3 px-4">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for meal in meals|slice(0, 5) %}
                                            <tr>
                                                <td class="px-4">
                                                    <div class="d-flex align-items-center">
                                                        {% if meal.image %}
                                                            <div class="me-3" style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden;">
                                                                <img src="{{ asset('uploads/meals/' ~ meal.image) }}" 
                                                                     alt="{{ meal.name }}"
                                                                     style="width: 100%; height: 100%; object-fit: cover;">
                                                            </div>
                                                        {% else %}
                                                            <div class="me-3 d-flex align-items-center justify-content-center" 
                                                                 style="width: 48px; height: 48px; background: rgba(16, 185, 129, 0.1); border-radius: 8px;">
                                                                <i class="fas fa-bacon" style="color: var(--primary-green);"></i>
                                                            </div>
                                                        {% endif %}
                                                        <div>
                                                            <h6 class="mb-0">{{ meal.name }}</h6>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="text-muted small">{{ meal.description|slice(0, 40) }}{% if meal.description|length > 40 %}...{% endif %}</span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                                                        <i class="fas fa-fire me-2"></i>{{ meal.calories }}
                                                    </span>
                                                </td>
                                                <td>
                                                    {% if meal.protein %}
                                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                                            {{ meal.protein }}g
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted small">—</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    {% if meal.carbs %}
                                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2">
                                                            {{ meal.carbs }}g
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted small">—</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    {% if meal.fat %}
                                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2">
                                                            {{ meal.fat }}g
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted small">—</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    {% if meal.nutritionPlans|length > 0 %}
                                                        <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2">
                                                            <i class="fas fa-utensils me-2"></i>{{ meal.nutritionPlans|length }} plans
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted small">Not assigned</span>
                                                    {% endif %}
                                                </td>
                                                <td class="px-4">
                                                    <div class="btn-group" role="group">
                                                        <a href="{{ path('app_coach_meal_edit', {'id': meal.id}) }}" 
                                                           class="btn btn-sm btn-outline-secondary rounded-start-pill px-3"
                                                           title="Edit Meal">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form method="post" action="{{ path('app_coach_meal_delete', {'id': meal.id}) }}" 
                                                              onsubmit="return confirm('Are you sure you want to delete this meal?');"
                                                              style="display: inline;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ meal.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-end-pill px-3" title="Delete Meal">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                                
                                <!-- Nutrition Summary Row -->
                                <div class="p-4 bg-light border-top">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-white p-2 me-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-fire" style="color: var(--primary-green);"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Avg Calories</small>
                                                    <strong>{% if meals|length > 0 %}{{ (meals|reduce((sum, meal) => sum + meal.calories, 0) / meals|length)|round }}{% else %}0{% endif %}</strong>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-white p-2 me-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-drumstick-bite" style="color: var(--primary-green);"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Avg Protein</small>
                                                    <strong>{% if meals|length > 0 %}{{ (meals|reduce((sum, meal) => sum + meal.protein, 0) / meals|length)|round }}g{% else %}0g{% endif %}</strong>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-white p-2 me-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-bread-slice" style="color: var(--primary-green);"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Avg Carbs</small>
                                                    <strong>{% if meals|length > 0 %}{{ (meals|reduce((sum, meal) => sum + meal.carbs, 0) / meals|length)|round }}g{% else %}0g{% endif %}</strong>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-white p-2 me-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-oil-can" style="color: var(--primary-green);"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Avg Fat</small>
                                                    <strong>{% if meals|length > 0 %}{{ (meals|reduce((sum, meal) => sum + meal.fat, 0) / meals|length)|round }}g{% else %}0g{% endif %}</strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                {% if meals|length > 5 %}
                                <div class="p-4 text-center border-top">
                                    <a href="#" class="text-decoration-none" style="color: var(--primary-green);">
                                        View all {{ meals|length }} meals <i class="fas fa-arrow-right ms-2"></i>
                                    </a>
                                </div>
                                {% endif %}
                            {% else %}
                                <div class="text-center py-5">
                                    <div class="empty-state">
                                        <i class="fas fa-bacon fa-4x text-muted mb-3"></i>
                                        <h6 class="text-muted">No meals created yet</h6>
                                        <p class="text-muted small mb-4">Get started by adding your first meal</p>
                                        <a href="{{ path('app_coach_meal_new') }}" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                            <i class="fas fa-plus-circle me-2"></i>Add Your First Meal
                                        </a>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<style>
:root {
    --primary-green: #10b981;
}

body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
}

.admin-wrapper {
    position: relative;
}

.admin-sidebar {
    box-shadow: 4px 0 10px rgba(0,0,0,0.1);
}

.admin-sidebar.collapsed {
    width: 80px !important;
}

.admin-sidebar.collapsed .sidebar-text {
    display: none;
}

.admin-sidebar.collapsed .nav-link {
    justify-content: center;
    padding: 12px !important;
}

.admin-sidebar.collapsed .nav-link i {
    margin-right: 0 !important;
}

.admin-sidebar.collapsed .badge {
    display: none;
}

.admin-sidebar.collapsed .admin-profile {
    justify-content: center;
}

.admin-sidebar.collapsed .admin-profile .avatar {
    margin-right: 0 !important;
}

#mainContent.expanded {
    margin-left: 80px !important;
    width: calc(100% - 80px) !important;
}

.nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    white-space: nowrap;
}

.nav-link.active {
    box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
}

.avatar-circle {
    transition: transform 0.3s;
}

.avatar-circle:hover {
    transform: scale(1.1);
}

/* Table row hover effect */
tbody tr:hover {
    background-color: rgba(16, 185, 129, 0.05);
}

/* Custom scrollbar */
.admin-main::-webkit-scrollbar {
    width: 8px;
}

.admin-main::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.admin-main::-webkit-scrollbar-thumb {
    background: var(--primary-green);
    border-radius: 4px;
}

.admin-main::-webkit-scrollbar-thumb:hover {
    background: #059669;
}

/* Hide navbar from base template if any */
.navbar, header, .top-navbar {
    display: none !important;
}

.empty-state {
    padding: 3rem;
}
</style>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
// Sidebar toggle functionality
document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    const toggleIcon = document.getElementById('toggleIcon');
    
    // Check local storage for sidebar state
    const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        mainContent.classList.add('expanded');
        toggleIcon.classList.remove('fa-chevron-left');
        toggleIcon.classList.add('fa-chevron-right');
    }
    
    toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.classList.remove('fa-chevron-left');
            toggleIcon.classList.add('fa-chevron-right');
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.classList.remove('fa-chevron-right');
            toggleIcon.classList.add('fa-chevron-left');
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    });
});

function toggleSubmenu(event, submenuId) {
    event.preventDefault();
    const submenu = document.getElementById(submenuId);
    const arrow = submenuId === 'nutritionSubmenu' ? document.getElementById('nutritionMenuArrow') : document.getElementById('mealsMenuArrow');
    
    if (submenu.style.display === 'none' || !submenu.style.display) {
        submenu.style.display = 'block';
        arrow.style.transform = 'rotate(180deg)';
    } else {
        submenu.style.display = 'none';
        arrow.style.transform = 'rotate(0deg)';
    }
}
</script>
{% endblock %}