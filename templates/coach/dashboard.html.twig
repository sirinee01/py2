{% extends 'base.html.twig' %}

{% block title %}Coach Dashboard - Sports Management{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4" style="color: var(--primary-green);">Coach Dashboard</h1>
            
            <!-- Quick Actions -->
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Nutrition Plans</h5>
                            <h2 style="color: var(--primary-green);">{{ nutritionPlans|length }}</h2>
                            <a href="{{ path('app_coach_nutrition_plan_new') }}" class="btn btn-primary-custom mt-2">Create New</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">Meals</h5>
                            <h2 style="color: var(--primary-green);">{{ meals|length }}</h2>
                            <a href="{{ path('app_coach_meal_new') }}" class="btn btn-primary-custom mt-2">Add New Meal</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card card-custom text-center">
                        <div class="card-body">
                            <h5 class="card-title">My Athletes</h5>
                            <h2 style="color: var(--primary-green);">0</h2>
                            <button class="btn btn-outline-primary-custom mt-2" disabled>Manage Athletes</button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Nutrition Plans Section -->
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="card card-custom">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background-color: var(--primary-green); color: white;">
                            <h5 class="mb-0">My Nutrition Plans</h5>
                            <a href="{{ path('app_coach_nutrition_plan_new') }}" class="btn btn-light btn-sm">+ New Plan</a>
                        </div>
                        <div class="card-body">
                            {% if nutritionPlans|length > 0 %}
                                <div class="row">
                                    {% for plan in nutritionPlans %}
                                    <div class="col-md-6 mb-3">
                                        <div class="card h-100">
                                            <div class="card-body">
                                                <h5 class="card-title">{{ plan.name }}</h5>
                                                <p class="card-text">{{ plan.description|slice(0, 100) }}...</p>
                                                <div class="mb-2">
                                                    <small class="text-muted">Duration: {{ plan.duration }} days</small>
                                                </div>
                                                <div class="mb-3">
                                                    <small class="text-muted">Objective: {{ plan.objective|slice(0, 50) }}...</small>
                                                </div>
                                                <div class="d-flex justify-content-between">
                                                    <a href="{{ path('app_coach_nutrition_plan_view', {'id': plan.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
                                                    <a href="{{ path('app_coach_nutrition_plan_edit', {'id': plan.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                                                    <form action="{{ path('app_coach_nutrition_plan_delete', {'id': plan.id}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this plan?');" style="display: inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="card-footer">
                                                <small class="text-muted">Created: {{ plan.createdAt|date('Y-m-d') }}</small>
                                            </div>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-center text-muted">No nutrition plans created yet.</p>
                                <div class="text-center">
                                    <a href="{{ path('app_coach_nutrition_plan_new') }}" class="btn btn-primary-custom">Create Your First Nutrition Plan</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Meals Section -->
                <div class="col-12">
                    <div class="card card-custom">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background-color: var(--primary-green); color: white;">
                            <h5 class="mb-0">My Meals</h5>
                            <a href="{{ path('app_coach_meal_new') }}" class="btn btn-light btn-sm">+ New Meal</a>
                        </div>
                        <div class="card-body">
                            {% if meals|length > 0 %}
                                <div class="row">
                                    {% for meal in meals %}
                                    <div class="col-md-4 mb-3">
                                        <div class="card h-100">
                                            {% if meal.image %}
                                            <img src="{{ asset('uploads/meals/' ~ meal.image) }}" class="card-img-top" alt="{{ meal.name }}" style="height: 150px; object-fit: cover;">
                                            {% else %}
                                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 150px;">
                                                <span style="color: var(--primary-green);">No Image</span>
                                            </div>
                                            {% endif %}
                                            <div class="card-body">
                                                <h5 class="card-title">{{ meal.name }}</h5>
                                                <p class="card-text">{{ meal.description|slice(0, 80) }}...</p>
                                                <div class="mb-2">
                                                    <span class="badge bg-primary">{{ meal.calories }} cal</span>
                                                    {% if meal.protein %}<span class="badge bg-success ms-1">{{ meal.protein }}g protein</span>{% endif %}
                                                </div>
                                                <div class="d-flex justify-content-between">
                                                    <a href="{{ path('app_coach_meal_edit', {'id': meal.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                                                    <form action="{{ path('app_coach_meal_delete', {'id': meal.id}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this meal?');" style="display: inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ meal.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-center text-muted">No meals created yet.</p>
                                <div class="text-center">
                                    <a href="{{ path('app_coach_meal_new') }}" class="btn btn-primary-custom">Create Your First Meal</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}