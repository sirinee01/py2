{% extends 'base.html.twig' %}

{% block title %}Edit Meal - Coach Dashboard{% endblock %}

{% block body %}
<div class="admin-wrapper d-flex" style="min-height: 100vh; width: 100%; margin: 0; padding: 0;">
    <!-- Sidebar (same as New Meal page) -->
    <aside class="admin-sidebar" id="sidebar" style="width: 280px; background: linear-gradient(180deg, #1a2e35 0%, #0f1e24 100%); min-height: 100vh; transition: width 0.3s ease; position: fixed; left: 0; top: 0; bottom: 0; z-index: 1000; overflow-y: auto; overflow-x: hidden;">
        <!-- ... same sidebar as New Meal page ... -->
    </aside>

    <!-- Main Content -->
    <main class="admin-main" id="mainContent" style="margin-left: 280px; width: calc(100% - 280px); background: #f8f9fa; min-height: 100vh; transition: margin-left 0.3s ease, width 0.3s ease;">
        
        <!-- Content Area -->
        <div class="content-area p-4">
            
            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px; border-left: 4px solid {% if type == 'success' %}var(--primary-green){% elseif type == 'error' %}#dc3545{% else %}#0dcaf0{% endif %};">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                {% if type == 'success' %}
                                    <i class="fas fa-check-circle" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                {% elseif type == 'error' %}
                                    <i class="fas fa-exclamation-circle" style="color: #dc3545; font-size: 1.5rem;"></i>
                                {% else %}
                                    <i class="fas fa-info-circle" style="color: #0dcaf0; font-size: 1.5rem;"></i>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1">
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_coach_dashboard') }}" style="color: var(--primary-green); text-decoration: none;">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_coach_dashboard') }}#meals" style="color: var(--primary-green); text-decoration: none;">Meals</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit {{ meal.name }}</li>
                </ol>
            </nav>
            
            <!-- Edit Meal Card -->
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                        <div class="card-header bg-white border-0 p-4">
                            <div class="d-flex align-items-center">
                                <div class="icon-circle me-3" style="width: 60px; height: 60px; background: rgba(16, 185, 129, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-edit" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1" style="color: var(--primary-green);">Edit Meal</h4>
                                    <p class="text-muted small mb-0">{{ meal.name }}</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="card-body p-4">
                            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'needs-validation'}}) }}
                                
                                <div class="row">
                                    <div class="col-md-6 mb-4">
                                        {{ form_label(form.name, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-tag" style="color: var(--primary-green);"></i>
                                            </span>
                                            {{ form_widget(form.name, {'attr': {
                                                'class': 'form-control border-0 py-3' ~ (form.name.vars.errors|length ? ' is-invalid' : ''),
                                                'placeholder': 'Enter meal name',
                                                'style': 'background: #f8f9fa;'
                                            }}) }}
                                        </div>
                                        {% if form.name.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.name.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    <div class="col-md-6 mb-4">
                                        {{ form_label(form.calories, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-fire" style="color: var(--primary-green);"></i>
                                            </span>
                                            {{ form_widget(form.calories, {'attr': {
                                                'class': 'form-control border-0 py-3' ~ (form.calories.vars.errors|length ? ' is-invalid' : ''),
                                                'placeholder': 'Calories',
                                                'style': 'background: #f8f9fa;'
                                            }}) }}
                                        </div>
                                        {% if form.calories.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.calories.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0" style="background: white; align-items: flex-start;">
                                            <i class="fas fa-align-left" style="color: var(--primary-green);"></i>
                                        </span>
                                        {{ form_widget(form.description, {'attr': {
                                            'class': 'form-control border-0 py-3' ~ (form.description.vars.errors|length ? ' is-invalid' : ''),
                                            'placeholder': 'Describe the meal, ingredients, preparation method...',
                                            'rows': 4,
                                            'style': 'background: #f8f9fa;'
                                        }}) }}
                                    </div>
                                    {% if form.description.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.description.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-4 mb-4">
                                        {{ form_label(form.protein, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-drumstick-bite" style="color: var(--primary-green);"></i>
                                            </span>
                                            {{ form_widget(form.protein, {'attr': {
                                                'class': 'form-control border-0 py-3' ~ (form.protein.vars.errors|length ? ' is-invalid' : ''),
                                                'placeholder': 'Protein (g)',
                                                'style': 'background: #f8f9fa;'
                                            }}) }}
                                        </div>
                                        {% if form.protein.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.protein.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    <div class="col-md-4 mb-4">
                                        {{ form_label(form.carbs, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-bread-slice" style="color: var(--primary-green);"></i>
                                            </span>
                                            {{ form_widget(form.carbs, {'attr': {
                                                'class': 'form-control border-0 py-3' ~ (form.carbs.vars.errors|length ? ' is-invalid' : ''),
                                                'placeholder': 'Carbs (g)',
                                                'style': 'background: #f8f9fa;'
                                            }}) }}
                                        </div>
                                        {% if form.carbs.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.carbs.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    <div class="col-md-4 mb-4">
                                        {{ form_label(form.fat, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                        <div class="input-group" style="border-radius: 12px; overflow: hidden;">
                                            <span class="input-group-text bg-white border-0" style="background: white;">
                                                <i class="fas fa-oil-can" style="color: var(--primary-green);"></i>
                                            </span>
                                            {{ form_widget(form.fat, {'attr': {
                                                'class': 'form-control border-0 py-3' ~ (form.fat.vars.errors|length ? ' is-invalid' : ''),
                                                'placeholder': 'Fat (g)',
                                                'style': 'background: #f8f9fa;'
                                            }}) }}
                                        </div>
                                        {% if form.fat.vars.errors|length %}
                                            <div class="invalid-feedback d-block">
                                                {% for error in form.fat.vars.errors %}
                                                    {{ error.message }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    
                                    {% if meal.image %}
                                    <div class="current-image mb-3 p-3 bg-light rounded-3">
                                        <p class="small text-muted mb-2">Current Image:</p>
                                        <img src="{{ asset('uploads/meals/' ~ meal.image) }}" 
                                             alt="{{ meal.name }}" 
                                             class="img-fluid rounded shadow-sm" 
                                             style="max-height: 120px; width: auto;">
                                    </div>
                                    {% endif %}
                                    
                                    <div class="upload-area p-4 text-center" style="border: 2px dashed #dee2e6; border-radius: 12px; background: #f8f9fa; cursor: pointer;" onclick="document.getElementById('{{ form.imageFile.vars.id }}').click();">
                                        <i class="fas fa-cloud-upload-alt fa-3x mb-3" style="color: var(--primary-green);"></i>
                                        <p class="mb-2"><strong>Click to upload new image</strong> or drag and drop</p>
                                        <p class="text-muted small mb-0">JPEG, PNG, GIF up to 1MB (leave empty to keep current)</p>
                                    </div>
                                    {{ form_widget(form.imageFile, {'attr': {
                                        'class': 'd-none',
                                        'accept': 'image/*'
                                    }}) }}
                                    <div id="imagePreview" class="mt-3 text-center" style="display: none;">
                                        <p class="small text-muted">New Image Preview:</p>
                                        <img src="" class="img-fluid rounded shadow-sm" style="max-height: 120px; width: auto;">
                                        <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="removeNewImage()">
                                            <i class="fas fa-times"></i> Remove
                                        </button>
                                    </div>
                                    {% if form.imageFile.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.imageFile.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="mb-4">
                                    {{ form_label(form.nutritionPlans, null, {'label_attr': {'class': 'form-label text-muted small fw-bold'}}) }}
                                    {{ form_widget(form.nutritionPlans, {'attr': {
                                        'class': 'form-select border-0 py-3' ~ (form.nutritionPlans.vars.errors|length ? ' is-invalid' : ''),
                                        'style': 'background: #f8f9fa; border-radius: 12px;',
                                        'size': 5
                                    }}) }}
                                    {% if form.nutritionPlans.vars.errors|length %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.nutritionPlans.vars.errors %}
                                                {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                    <small class="text-muted">Hold Ctrl/Cmd to select multiple plans</small>
                                </div>
                                
                                <!-- Nutrition Summary -->
                                <div class="bg-light p-4 rounded-3 mb-4" style="background: #f8f9fa;">
                                    <h6 class="small fw-bold text-muted mb-3">NUTRITION SUMMARY</h6>
                                    <div class="row text-center">
                                        <div class="col-3">
                                            <div class="rounded-circle bg-white p-3 mx-auto mb-2" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-fire" style="color: var(--primary-green);"></i>
                                            </div>
                                            <h6 class="mb-0">{{ meal.calories|default(0) }}</h6>
                                            <small class="text-muted">Calories</small>
                                        </div>
                                        <div class="col-3">
                                            <div class="rounded-circle bg-white p-3 mx-auto mb-2" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-drumstick-bite" style="color: var(--primary-green);"></i>
                                            </div>
                                            <h6 class="mb-0">{{ meal.protein|default(0) }}g</h6>
                                            <small class="text-muted">Protein</small>
                                        </div>
                                        <div class="col-3">
                                            <div class="rounded-circle bg-white p-3 mx-auto mb-2" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-bread-slice" style="color: var(--primary-green);"></i>
                                            </div>
                                            <h6 class="mb-0">{{ meal.carbs|default(0) }}g</h6>
                                            <small class="text-muted">Carbs</small>
                                        </div>
                                        <div class="col-3">
                                            <div class="rounded-circle bg-white p-3 mx-auto mb-2" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-oil-can" style="color: var(--primary-green);"></i>
                                            </div>
                                            <h6 class="mb-0">{{ meal.fat|default(0) }}g</h6>
                                            <small class="text-muted">Fat</small>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                    <a href="{{ path('app_coach_dashboard') }}" class="btn btn-link text-decoration-none" style="color: #6c757d;">
                                        <i class="fas fa-arrow-left me-2"></i>
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-success rounded-pill px-4" style="background: var(--primary-green); border: none;">
                                        <i class="fas fa-save me-2"></i>
                                        Update Meal
                                    </button>
                                </div>
                                
                            {{ form_end(form) }}
                        </div>
                    </div>
                    
                    <!-- Delete Option -->
                    <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <h6 class="mb-1" style="color: #dc3545;">Delete Meal</h6>
                                    <p class="text-muted small mb-0">Once deleted, this meal cannot be recovered.</p>
                                </div>
                                <form method="post" action="{{ path('app_coach_meal_delete', {'id': meal.id}) }}" 
                                      onsubmit="return confirm('Are you sure you want to delete this meal? This action cannot be undone.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ meal.id) }}">
                                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                                        <i class="fas fa-trash-alt me-2"></i>Delete Meal
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Same styles and additional scripts -->
<style>
/* Same styles as New Meal page */
:root {
    --primary-green: #10b981;
}
/* ... rest of styles ... */
</style>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
// Same sidebar toggle and submenu functions
document.addEventListener('DOMContentLoaded', function() {
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    const toggleIcon = document.getElementById('toggleIcon');
    
    const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        mainContent.classList.add('expanded');
        toggleIcon.classList.remove('fa-chevron-left');
        toggleIcon.classList.add('fa-chevron-right');
    }
    
    toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.classList.remove('fa-chevron-left');
            toggleIcon.classList.add('fa-chevron-right');
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.classList.remove('fa-chevron-right');
            toggleIcon.classList.add('fa-chevron-left');
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    });

    // Image upload preview
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const uploadArea = document.querySelector('.upload-area');
    
    if (imageInput) {
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const previewImg = imagePreview.querySelector('img');
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            }
        });
    }

    // Keep meals submenu open
    const mealsSubmenu = document.getElementById('mealsSubmenu');
    const mealsArrow = document.getElementById('mealsMenuArrow');
    if (mealsSubmenu) {
        mealsSubmenu.style.display = 'block';
        mealsArrow.style.transform = 'rotate(180deg)';
    }
});

function toggleSubmenu(event, submenuId) {
    event.preventDefault();
    const submenu = document.getElementById(submenuId);
    const arrow = submenuId === 'nutritionSubmenu' ? document.getElementById('nutritionMenuArrow') : document.getElementById('mealsMenuArrow');
    
    if (submenu.style.display === 'none' || !submenu.style.display) {
        submenu.style.display = 'block';
        arrow.style.transform = 'rotate(180deg)';
    } else {
        submenu.style.display = 'none';
        arrow.style.transform = 'rotate(0deg)';
    }
}

function removeNewImage() {
    const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    
    imageInput.value = '';
    imagePreview.style.display = 'none';
}
</script>
{% endblock %}