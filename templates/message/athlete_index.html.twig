{% extends 'base.html.twig' %}

{% block title %}Messages - Athlete Dashboard{% endblock %}

{% block body %}
<div class="athlete-wrapper" style="background: #f8f9fa; min-height: 100vh;">
    <!-- Top Navigation Bar (same as athlete dashboard) -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm px-4" style="border-bottom: 3px solid var(--primary-green);">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="{{ path('app_athlete_dashboard') }}">
                <span style="color: var(--primary-green); font-size: 1.8rem; font-weight: 700;">⚡</span>
                <span class="ms-2" style="font-weight: 600; color: #1a2e35;">MyNutrition</span>
            </a>
            
            <div class="d-flex align-items-center gap-3">
                <!-- Messages Icon (active) -->
                <div class="position-relative">
                    <a href="{{ path('app_messages_index') }}" class="btn btn-success rounded-circle p-2 d-flex align-items-center justify-content-center" 
                       style="width: 40px; height: 40px; background: var(--primary-green); border: none;">
                        <i class="fas fa-envelope text-white"></i>
                    </a>
                </div>
                
                <div class="dropdown">
                    <button class="btn btn-link dropdown-toggle text-dark" type="button" data-bs-toggle="dropdown">
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle me-2" style="width: 40px; height: 40px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                {{ app.user.name|first|upper }}
                            </div>
                            <span>{{ app.user.name }}</span>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{{ path('app_athlete_dashboard') }}"><i class="fas fa-home me-2"></i>Dashboard</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_athlete_progress') }}"><i class="fas fa-chart-line me-2"></i>Progress</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_messages_index') }}"><i class="fas fa-envelope me-2"></i>Messages</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 style="color: #1a2e35;">Messages</h2>
                <p class="text-muted">Communicate with your coach</p>
            </div>
        </div>

        <!-- Available Users Section (Start New Conversation) -->
        {% if availableUsers|length > 0 %}
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header bg-white border-0 p-4">
                <h5 class="mb-0" style="color: var(--primary-green);">Start a New Conversation</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    {% for availableUser in availableUsers %}
                    <div class="col-md-4">
                        <div class="d-flex align-items-center p-3" style="background: #f8f9fa; border-radius: 12px; border: 1px solid #e9ecef;">
                            <div class="avatar-circle me-3" style="width: 45px; height: 45px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                {{ availableUser.name|first|upper }}
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1">{{ availableUser.name }}</h6>
                                <small class="text-muted">{{ availableUser.roleType|capitalize }}</small>
                            </div>
                            <a href="{{ path('app_messages_start', {'userId': availableUser.id}) }}" 
                               class="btn btn-sm btn-success rounded-circle"
                               style="width: 35px; height: 35px; background: var(--primary-green); border: none;"
                               title="Start conversation">
                                <i class="fas fa-comment text-white"></i>
                            </a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Existing Conversations -->
        <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1" style="color: var(--primary-green);">Your Conversations</h5>
                    <p class="text-muted small mb-0">Stay connected with your coach</p>
                </div>
            </div>
            
            <div class="card-body p-0">
                {% if conversations|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for conversation in conversations %}
                            {% set other = conversation.getOtherParticipant(app.user) %}
                            {% set lastMessage = conversation.getLastMessage() %}
                            {% set unreadCount = conversation.messages|filter(m => m.sender != app.user and not m.isRead)|length %}
                            <a href="{{ path('app_messages_conversation', {'id': conversation.id}) }}" 
                               class="list-group-item list-group-item-action d-flex align-items-center p-4"
                               style="border-left: none; border-right: none; border-bottom: 1px solid #e9ecef; {% if unreadCount > 0 %}background-color: #f0f9ff;{% endif %} transition: all 0.3s;"
                               onmouseover="this.style.backgroundColor='#f8f9fa'; this.style.transform='translateX(5px)';" 
                               onmouseout="this.style.backgroundColor='{% if unreadCount > 0 %}#f0f9ff{% else %}white{% endif %}'; this.style.transform='translateX(0)';">
                                
                                <div class="avatar-circle me-3" style="width: 50px; height: 50px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 1.2rem; flex-shrink: 0;">
                                    {{ other.name|first|upper }}
                                </div>
                                
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <div class="d-flex align-items-center">
                                            <h6 class="mb-0 {% if unreadCount > 0 %}fw-bold{% endif %}">{{ other.name }}</h6>
                                            <span class="badge bg-primary bg-opacity-10 text-primary ms-2" style="font-size: 0.7rem;">{{ other.roleType|capitalize }}</span>
                                        </div>
                                        <small class="text-muted">{{ lastMessage ? lastMessage.createdAt|date('M d, H:i') : '' }}</small>
                                    </div>
                                    
                                    <p class="mb-0 text-truncate" style="max-width: 400px; color: #64748b;">
                                        {% if lastMessage %}
                                            {% if lastMessage.sender == app.user %}
                                                <span class="text-muted">You: </span>
                                            {% endif %}
                                            <span {% if unreadCount > 0 %}class="fw-semibold"{% endif %}>{{ lastMessage.content }}</span>
                                        {% else %}
                                            <span class="text-muted fst-italic">No messages yet</span>
                                        {% endif %}
                                    </p>
                                </div>
                                
                                {% if unreadCount > 0 %}
                                    <span class="badge bg-danger rounded-pill ms-3">{{ unreadCount }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <div class="empty-state">
                            <div class="mb-3">
                                <i class="fas fa-comments fa-4x" style="color: var(--primary-green); opacity: 0.3;"></i>
                            </div>
                            <h6 class="text-muted mb-2">No conversations yet</h6>
                            <p class="text-muted small mb-4">
                                {% if availableUsers|length > 0 %}
                                    Start a conversation with your coach above!
                                {% else %}
                                    No users available to message at this time.
                                {% endif %}
                            </p>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
:root {
    --primary-green: #10b981;
}

.athlete-wrapper {
    background: #f8f9fa;
}

.avatar-circle {
    transition: transform 0.3s;
}

.avatar-circle:hover {
    transform: scale(1.1);
}

.min-w-0 {
    min-width: 0;
}

.list-group-item {
    transition: all 0.3s ease;
    border-left: 3px solid transparent;
}

.list-group-item:hover {
    border-left-color: var(--primary-green);
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
}

.badge.bg-danger {
    animation: pulse 2s infinite;
}
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}