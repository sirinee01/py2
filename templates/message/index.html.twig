{% extends 'base.html.twig' %}

{% block title %}Messages - Sports Management{% endblock %}

{% block body %}
<div class="admin-wrapper d-flex" style="min-height: 100vh; width: 100%; margin: 0; padding: 0;">
    <!-- Sidebar (même que le dashboard) -->
    <aside class="admin-sidebar" id="sidebar" style="width: 280px; background: linear-gradient(180deg, #1a2e35 0%, #0f1e24 100%); min-height: 100vh; transition: width 0.3s ease; position: fixed; left: 0; top: 0; bottom: 0; z-index: 1000; overflow-y: auto; overflow-x: hidden;">
        <div class="sidebar-header p-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white mb-0" style="font-weight: 600; white-space: nowrap;">
                <span style="color: var(--primary-green);">⚡</span> <span class="sidebar-text">CoachPanel</span>
            </h3>
        </div>
        
        <div class="sidebar-menu p-3">
            <!-- Coach Profile -->
            <div class="admin-profile d-flex align-items-center p-3 mb-4" style="background: rgba(255,255,255,0.05); border-radius: 12px;">
                <div class="avatar me-3" style="width: 48px; height: 48px; background: var(--primary-green); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="fas fa-chalkboard-teacher text-white" style="font-size: 1.5rem;"></i>
                </div>
                <div class="sidebar-text" style="overflow: hidden;">
                    <h6 class="text-white mb-1" style="white-space: nowrap;">{{ app.user.name|default('Coach') }}</h6>
                    <p class="text-white-50 small mb-0" style="white-space: nowrap;">{{ app.user.email|default('coach@sports.com') }}</p>
                </div>
            </div>
            
            <!-- Navigation Menu -->
            <nav class="nav flex-column">
                <a href="{{ path('app_coach_dashboard') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-tachometer-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                
                <a href="{{ path('app_coach_athletes') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-users me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">My Athletes</span>
                </a>
                
                <!-- Nutrition Plans with dropdown -->
                <div class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8);" onclick="toggleSubmenu(event, 'nutritionSubmenu')" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                        <i class="fas fa-utensils me-3" style="width: 20px; flex-shrink: 0;"></i>
                        <span class="sidebar-text flex-grow-1">Nutrition Plans</span>
                        <i class="fas fa-chevron-down sidebar-text" id="nutritionMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                    </a>
                    <!-- Submenu -->
                    <div class="submenu" id="nutritionSubmenu" style="display: none; margin-left: 2.5rem; margin-bottom: 0.5rem;">
                        <a href="{{ path('app_coach_nutrition_plan_new') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-plus-circle me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Create New Plan</span>
                        </a>
                        <a href="{{ path('app_coach_dashboard') }}#plans" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-list me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">View All Plans</span>
                        </a>
                    </div>
                </div>
                
                <!-- Meals with dropdown -->
                <div class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8);" onclick="toggleSubmenu(event, 'mealsSubmenu')" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                        <i class="fas fa-bacon me-3" style="width: 20px; flex-shrink: 0;"></i>
                        <span class="sidebar-text flex-grow-1">Meals</span>
                        <i class="fas fa-chevron-down sidebar-text" id="mealsMenuArrow" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                    </a>
                    <!-- Submenu -->
                    <div class="submenu" id="mealsSubmenu" style="display: none; margin-left: 2.5rem; margin-bottom: 0.5rem;">
                        <a href="{{ path('app_coach_meal_new') }}" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-plus-circle me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">Add New Meal</span>
                        </a>
                        <a href="{{ path('app_coach_dashboard') }}#meals" class="nav-link d-flex align-items-center px-3 py-2 mb-1 rounded-3" style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)';">
                            <i class="fas fa-list me-2" style="width: 16px;"></i>
                            <span class="sidebar-text">View All Meals</span>
                        </a>
                    </div>
                </div>
                
                <!-- Messages (Active) -->
                <a href="{{ path('app_messages_index') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="background: var(--primary-green); color: white;">
                    <i class="fas fa-envelope me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text flex-grow-1">Messages</span>
                    <span class="badge bg-danger rounded-pill" id="sidebar-unread-count">0</span>
                </a>
                
                <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">
                
                <a href="{{ path('app_logout') }}" class="nav-link d-flex align-items-center px-3 py-3 mb-2 rounded-3" style="color: rgba(255,255,255,0.8); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,0,0,0.2)'; this.style.color='#ff6b6b';" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.8)';">
                    <i class="fas fa-sign-out-alt me-3" style="width: 20px; flex-shrink: 0;"></i>
                    <span class="sidebar-text">Logout</span>
                </a>
            </nav>
            
            <div class="btn btn-sm text-white d-flex justify-content-end">
                <button id="sidebarToggle" class="btn btn-sm text-white d-flex justify-content-end" style="background: transparent; border: none; font-size: 1.2rem;">
                    <i class="fas fa-chevron-left" id="toggleIcon"></i>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main" id="mainContent" style="margin-left: 280px; width: calc(100% - 280px); background: #f8f9fa; min-height: 100vh; transition: margin-left 0.3s ease, width 0.3s ease;">
        <!-- Top bar with message and notification icons -->
        <div class="top-bar bg-white px-4 py-3 d-flex justify-content-end align-items-center shadow-sm" style="border-bottom: 1px solid #dee2e6;">
            <div class="d-flex align-items-center gap-3">
                <!-- Messages Icon with unread count (Active) -->
                <div class="position-relative">
                    <a href="{{ path('app_messages_index') }}" class="text-dark position-relative d-inline-block">
                        <i class="fas fa-envelope" style="font-size: 1.4rem; color: var(--primary-green);"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" 
                              id="unread-message-count" 
                              style="font-size: 0.7rem; min-width: 18px; height: 18px; display: flex; align-items: center; justify-content: center;">
                            0
                        </span>
                    </a>
                </div>
                
                <!-- Notifications Icon with dropdown -->
                <div class="dropdown">
                    <button class="btn btn-light rounded-circle p-2 d-flex align-items-center justify-content-center" 
                            type="button" 
                            id="notificationDropdown" 
                            data-bs-toggle="dropdown" 
                            aria-expanded="false"
                            style="width: 40px; height: 40px; border: none; background: #f1f5f9;">
                        <i class="fas fa-bell" style="font-size: 1.2rem; color: #475569;"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" 
                              id="unread-notification-count" 
                              style="font-size: 0.7rem; min-width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; margin-top: -5px; margin-left: -10px;">
                            0
                        </span>
                    </button>
                    
                    <!-- Notifications Dropdown Menu -->
                    <div class="dropdown-menu dropdown-menu-end shadow-lg" 
                         aria-labelledby="notificationDropdown" 
                         style="width: 350px; border: none; border-radius: 12px; margin-top: 10px;">
                        <div class="dropdown-header d-flex justify-content-between align-items-center py-3 px-4" style="border-bottom: 1px solid #e9ecef;">
                            <h6 class="mb-0 fw-bold">Notifications</h6>
                            <span class="badge bg-primary rounded-pill" id="notification-total">0</span>
                        </div>
                        <div class="notification-list" style="max-height: 400px; overflow-y: auto;">
                            <!-- Notifications will be loaded here -->
                        </div>
                        <div class="dropdown-footer text-center py-3" style="border-top: 1px solid #e9ecef;">
                            <a href="#" class="text-decoration-none small" style="color: var(--primary-green);">View all notifications</a>
                        </div>
                    </div>
                </div>
                
                <!-- User Profile Dropdown -->
                <div class="dropdown ms-2">
                    <button class="btn p-0 d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center" 
                             style="width: 40px; height: 40px; background: var(--primary-green) !important;">
                            <span class="text-white fw-bold">{{ app.user.name|first|default('C')|upper }}</span>
                        </div>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end shadow-sm" style="border: none; border-radius: 12px;">
                        <div class="px-4 py-3">
                            <p class="fw-bold mb-1">{{ app.user.name|default('Coach') }}</p>
                            <small class="text-muted">{{ app.user.email|default('coach@sports.com') }}</small>
                        </div>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item py-2 px-4" href="#">
                            <i class="fas fa-user me-2" style="color: var(--primary-green);"></i> Profile
                        </a>
                        <a class="dropdown-item py-2 px-4" href="#">
                            <i class="fas fa-cog me-2" style="color: var(--primary-green);"></i> Settings
                        </a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item py-2 px-4" href="{{ path('app_logout') }}">
                            <i class="fas fa-sign-out-alt me-2 text-danger"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="content-area p-4">
            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px; border-left: 4px solid {% if type == 'success' %}var(--primary-green){% elseif type == 'error' %}#dc3545{% else %}#0dcaf0{% endif %};">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                {% if type == 'success' %}
                                    <i class="fas fa-check-circle" style="color: var(--primary-green); font-size: 1.5rem;"></i>
                                {% elseif type == 'error' %}
                                    <i class="fas fa-exclamation-circle" style="color: #dc3545; font-size: 1.5rem;"></i>
                                {% else %}
                                    <i class="fas fa-info-circle" style="color: #0dcaf0; font-size: 1.5rem;"></i>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1">
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_coach_dashboard') }}" style="color: var(--primary-green); text-decoration: none;">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Messages</li>
                </ol>
            </nav>
            
            <!-- Welcome Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1" style="color: #1a2e35;">Messages</h2>
                    <p class="text-muted">Communicate with your athletes and team members</p>
                </div>
                <div>
                    <span class="badge bg-light text-dark p-3 rounded-3" style="box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <i class="far fa-envelope me-2" style="color: var(--primary-green);"></i>
                        {{ conversations|length }} conversations
                    </span>
                </div>
            </div>

            <!-- Available Users Section (Start New Conversation) -->
            {% if availableUsers|length > 0 %}
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; overflow: hidden;">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="mb-0" style="color: var(--primary-green);">Start a New Conversation</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        {% for availableUser in availableUsers %}
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3" style="background: #f8f9fa; border-radius: 12px; border: 1px solid #e9ecef;">
                                <div class="avatar-circle me-3" style="width: 45px; height: 45px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                    {{ availableUser.name|first|upper }}
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">{{ availableUser.name }}</h6>
                                    <small class="text-muted">{{ availableUser.roleType|capitalize }}</small>
                                </div>
                                <a href="{{ path('app_messages_start', {'userId': availableUser.id}) }}" 
                                   class="btn btn-sm btn-success rounded-circle"
                                   style="width: 35px; height: 35px; background: var(--primary-green); border: none;"
                                   title="Start conversation">
                                    <i class="fas fa-comment text-white"></i>
                                </a>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            <!-- Existing Conversations -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1" style="color: var(--primary-green);">Your Conversations</h5>
                        <p class="text-muted small mb-0">Stay connected with your team</p>
                    </div>
                </div>
                
                <div class="card-body p-0">
                    {% if conversations|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for conversation in conversations %}
                                {% set other = conversation.getOtherParticipant(app.user) %}
                                {% set lastMessage = conversation.getLastMessage() %}
                                {% set unreadCount = conversation.messages|filter(m => m.sender != app.user and not m.isRead)|length %}
                                <a href="{{ path('app_messages_conversation', {'id': conversation.id}) }}" 
                                   class="list-group-item list-group-item-action d-flex align-items-center p-4"
                                   style="border-left: none; border-right: none; {% if unreadCount > 0 %}background-color: #f0f9ff;{% endif %} border-bottom: 1px solid #e9ecef;">
                                    <div class="avatar-circle me-3" style="width: 50px; height: 50px; background: var(--primary-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 1.2rem;">
                                        {{ other.name|first|upper }}
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="mb-0 {% if unreadCount > 0 %}fw-bold{% endif %}">{{ other.name }}</h6>
                                            <small class="text-muted">{{ lastMessage ? lastMessage.createdAt|date('M d, H:i') : '' }}</small>
                                        </div>
                                        <p class="mb-0 text-truncate" style="max-width: 400px;">
                                            {% if lastMessage %}
                                                {% if lastMessage.sender == app.user %}
                                                    <span class="text-muted">You: </span>
                                                {% endif %}
                                                <span {% if unreadCount > 0 %}class="fw-semibold"{% endif %}>{{ lastMessage.content }}</span>
                                            {% else %}
                                                <span class="text-muted fst-italic">No messages yet</span>
                                            {% endif %}
                                        </p>
                                    </div>
                                    {% if unreadCount > 0 %}
                                        <span class="badge bg-danger rounded-pill ms-3">{{ unreadCount }}</span>
                                    {% endif %}
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <div class="empty-state">
                                <i class="fas fa-comments fa-4x text-muted mb-3"></i>
                                <h6 class="text-muted">No conversations yet</h6>
                                <p class="text-muted small mb-4">
                                    {% if availableUsers|length > 0 %}
                                        Start a conversation with one of the users above!
                                    {% else %}
                                        No users available to message at this time.
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </main>
</div>

<style>
:root {
    --primary-green: #10b981;
}

body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
}

.admin-wrapper {
    position: relative;
}

.admin-sidebar {
    box-shadow: 4px 0 10px rgba(0,0,0,0.1);
}

.admin-sidebar.collapsed {
    width: 80px !important;
}

.admin-sidebar.collapsed .sidebar-text {
    display: none;
}

.admin-sidebar.collapsed .nav-link {
    justify-content: center;
    padding: 12px !important;
}

.admin-sidebar.collapsed .nav-link i {
    margin-right: 0 !important;
}

.admin-sidebar.collapsed .badge {
    display: none;
}

.admin-sidebar.collapsed .admin-profile {
    justify-content: center;
}

.admin-sidebar.collapsed .admin-profile .avatar {
    margin-right: 0 !important;
}

#mainContent.expanded {
    margin-left: 80px !important;
    width: calc(100% - 80px) !important;
}

.nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    white-space: nowrap;
}

.nav-link.active {
    box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
}

.avatar-circle {
    transition: transform 0.3s;
}

.avatar-circle:hover {
    transform: scale(1.1);
}

.list-group-item {
    transition: all 0.2s;
}

.list-group-item:hover {
    background-color: #f8f9fa !important;
    transform: translateX(5px);
}

/* Custom scrollbar */
.admin-main::-webkit-scrollbar {
    width: 8px;
}

.admin-main::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.admin-main::-webkit-scrollbar-thumb {
    background: var(--primary-green);
    border-radius: 4px;
}

.admin-main::-webkit-scrollbar-thumb:hover {
    background: #059669;
}

/* Hide navbar from base template if any */
.navbar, header, .top-navbar {
    display: none !important;
}

.empty-state {
    padding: 3rem;
}
</style>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
// Sidebar toggle functionality
document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    const toggleIcon = document.getElementById('toggleIcon');
    
    // Check local storage for sidebar state
    const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        mainContent.classList.add('expanded');
        toggleIcon.classList.remove('fa-chevron-left');
        toggleIcon.classList.add('fa-chevron-right');
    }
    
    toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.classList.remove('fa-chevron-left');
            toggleIcon.classList.add('fa-chevron-right');
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.classList.remove('fa-chevron-right');
            toggleIcon.classList.add('fa-chevron-left');
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    });

    // Update unread message count
    function updateUnreadCount() {
        fetch('{{ path('app_messages_unread_count') }}')
            .then(response => response.json())
            .then(data => {
                document.getElementById('unread-message-count').textContent = data.count;
                document.getElementById('sidebar-unread-count').textContent = data.count;
            })
            .catch(error => console.error('Error fetching unread count:', error));
    }

    // Initialize counts on page load
    updateUnreadCount();
    
    // Update counts every 30 seconds
    setInterval(updateUnreadCount, 30000);
});

function toggleSubmenu(event, submenuId) {
    event.preventDefault();
    const submenu = document.getElementById(submenuId);
    const arrow = submenuId === 'nutritionSubmenu' ? document.getElementById('nutritionMenuArrow') : document.getElementById('mealsMenuArrow');
    
    if (submenu.style.display === 'none' || !submenu.style.display) {
        submenu.style.display = 'block';
        arrow.style.transform = 'rotate(180deg)';
    } else {
        submenu.style.display = 'none';
        arrow.style.transform = 'rotate(0deg)';
    }
}
</script>
{% endblock %}