{# templates/onboarding/step2.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Your Goals - Step 2{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --primary-green: #10b981;
        --primary-dark: #059669;
    }
    
    .onboarding-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .onboarding-card {
        background: white;
        border-radius: 30px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        width: 100%;
        max-width: 800px;
        overflow: hidden;
        animation: slideUp 0.5s ease;
    }
    
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .progress-header {
        background: linear-gradient(135deg, var(--primary-green), #3b82f6);
        padding: 30px;
        color: white;
    }
    
    .progress-steps {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        position: relative;
    }
    
    .progress-steps::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: rgba(255,255,255,0.3);
        transform: translateY(-50%);
        z-index: 1;
    }
    
    .step {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        position: relative;
        z-index: 2;
        transition: all 0.3s ease;
    }
    
    .step.active {
        background: white;
        color: var(--primary-green);
        transform: scale(1.1);
        box-shadow: 0 0 20px rgba(255,255,255,0.5);
    }
    
    .step.completed {
        background: white;
        color: var(--primary-green);
    }
    
    .step.completed::after {
        content: '✓';
    }
    
    .progress-bar-container {
        width: 100%;
        height: 8px;
        background: rgba(255,255,255,0.3);
        border-radius: 4px;
        margin-top: 20px;
    }
    
    .progress-bar-fill {
        height: 100%;
        background: white;
        border-radius: 4px;
        transition: width 0.3s ease;
        width: {{ progress }}%;
    }
    
    .onboarding-body {
        padding: 40px;
    }
    
    .step-title {
        font-size: 1.8rem;
        font-weight: 600;
        margin-bottom: 10px;
        color: #333;
    }
    
    .step-subtitle {
        color: #666;
        margin-bottom: 30px;
    }
    
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        display: block;
    }
    
    .form-control {
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 15px;
        width: 100%;
        transition: all 0.3s ease;
    }
    
    .form-control:focus {
        border-color: var(--primary-green);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
        outline: none;
    }
    
    .radio-group {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 10px;
    }
    
    .radio-option {
        background: #f9fafb;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
    }
    
    .radio-option:hover {
        border-color: var(--primary-green);
        background: #f0fdf4;
    }
    
    .radio-option.selected {
        border-color: var(--primary-green);
        background: #f0fdf4;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }
    
    .radio-option input[type="radio"] {
        display: none;
    }
    
    .btn-next {
        background: linear-gradient(135deg, var(--primary-green), #3b82f6);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px 30px;
        font-size: 1.1rem;
        font-weight: 600;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 20px;
    }
    
    .btn-next:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
    }
    
    .btn-prev {
        background: white;
        color: var(--primary-green);
        border: 2px solid var(--primary-green);
        border-radius: 12px;
        padding: 15px 30px;
        font-size: 1.1rem;
        font-weight: 600;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
    }
    
    .btn-prev:hover {
        background: #f0fdf4;
        transform: translateY(-2px);
    }
    
    .recommendation-box {
        background: #f0f9ff;
        border-left: 4px solid #3b82f6;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 30px;
    }
    
    .recommendation-title {
        font-weight: 600;
        color: #1e40af;
        margin-bottom: 15px;
    }
    
    .metric-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
    }
    
    .metric-card {
        background: white;
        padding: 15px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    
    .metric-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary-green);
    }
    
    .metric-label {
        font-size: 0.9rem;
        color: #666;
        margin-top: 5px;
    }
</style>
{% endblock %}

{% block body %}
<div class="onboarding-page">
    <div class="onboarding-card">
        <div class="progress-header">
            <div class="progress-steps">
                <div class="step completed">1</div>
                <div class="step active">2</div>
                <div class="step">3</div>
                <div class="step">4</div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar-fill" style="width: {{ progress }}%"></div>
            </div>
        </div>
        
        <div class="onboarding-body">
            <h1 class="step-title">Your Fitness Goals 🎯</h1>
            <p class="step-subtitle">Tell us what you want to achieve</p>
            
            {% if recommendations.bmi or recommendations.bmr %}
            <div class="recommendation-box">
                <h4 class="recommendation-title">Your Health Metrics</h4>
                <div class="metric-grid">
                    {% if recommendations.bmi %}
                    <div class="metric-card">
                        <div class="metric-value">{{ recommendations.bmi }}</div>
                        <div class="metric-label">BMI ({{ recommendations.bmiCategory|default('normal')|capitalize }})</div>
                    </div>
                    {% endif %}
                    {% if recommendations.bmr %}
                    <div class="metric-card">
                        <div class="metric-value">{{ recommendations.bmr }}</div>
                        <div class="metric-label">BMR (calories/day)</div>
                    </div>
                    {% endif %}
                    {% if recommendations.tdee %}
                    <div class="metric-card">
                        <div class="metric-value">{{ recommendations.tdee }}</div>
                        <div class="metric-label">TDEE (calories/day)</div>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            
            {{ form_start(form, {'attr': {'id': 'onboardingForm'}}) }}
                
                <div class="form-group">
                    <label class="form-label">{{ form.primaryGoal.vars.label }}</label>
                    <div class="radio-group">
                        {% for choice in form.primaryGoal %}
                            <label class="radio-option">
                                {{ form_widget(choice) }}
                                {{ choice.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.primaryGoal) }}
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">{{ form.targetWeight.vars.label }}</label>
                            {{ form_widget(form.targetWeight) }}
                            {{ form_errors(form.targetWeight) }}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">{{ form.goalTimeline.vars.label }}</label>
                            <div class="radio-group" style="grid-template-columns: repeat(2, 1fr);">
                                {% for choice in form.goalTimeline %}
                                    <label class="radio-option">
                                        {{ form_widget(choice) }}
                                        {{ choice.vars.label }}
                                    </label>
                                {% endfor %}
                            </div>
                            {{ form_errors(form.goalTimeline) }}
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">{{ form.dailyCalorieIntake.vars.label }}</label>
                            {{ form_widget(form.dailyCalorieIntake) }}
                            {{ form_errors(form.dailyCalorieIntake) }}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">{{ form.dailyWaterIntake.vars.label }}</label>
                            {{ form_widget(form.dailyWaterIntake) }}
                            {{ form_errors(form.dailyWaterIntake) }}
                        </div>
                    </div>
                </div>
                
                <button type="submit" class="btn-next">
                    Continue to Nutrition
                    <i class="fas fa-arrow-right ms-2"></i>
                </button>
                
                <a href="{{ path('app_onboarding_step1') }}" class="btn-prev text-center d-block">
                    <i class="fas fa-arrow-left me-2"></i>
                    Back to Step 1
                </a>
                
            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
// Add visual feedback for selected radio options
document.querySelectorAll('.radio-option input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', function() {
        const name = this.name;
        document.querySelectorAll(`input[name="${name}"]`).forEach(input => {
            input.closest('.radio-option').classList.remove('selected');
        });
        
        if (this.checked) {
            this.closest('.radio-option').classList.add('selected');
        }
    });
    
    if (radio.checked) {
        radio.closest('.radio-option').classList.add('selected');
    }
});
</script>
{% endblock %}