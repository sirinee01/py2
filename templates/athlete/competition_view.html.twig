{% extends 'base.html.twig' %}

{% block title %}{{ competition.name }} - Athlete View{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_athlete_competitions') }}">Competitions</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        {{ competition.name }}
                    </li>
                </ol>
            </nav>

            <div class="card card-custom mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h2 class="mb-3" style="color: var(--primary-green);">{{ competition.name }}</h2>
                            <div class="mb-4">
                                {{ competition.description|nl2br }}
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-calendar"></i> Start Date:</strong><br>
                                    {{ competition.startDate|date('F d, Y H:i') }}</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-calendar"></i> End Date:</strong><br>
                                    {{ competition.endDate|date('F d, Y H:i') }}</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-map-marker-alt"></i> Location:</strong><br>
                                    {{ competition.location }}</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-users"></i> Participants:</strong><br>
                                    {{ competition.applications|length }}/{{ competition.maxParticipants }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            {% if competition.image %}
                                <img src="{{ asset('uploads/competitions/' ~ competition.image) }}" 
                                     class="img-fluid rounded" 
                                     alt="{{ competition.name }}">
                            {% endif %}
                            
                            <div class="mt-3">
                                <span class="badge {% if competition.status == 'upcoming' %}bg-warning{% elseif competition.status == 'ongoing' %}bg-success{% else %}bg-secondary{% endif %} fs-6">
                                    {{ competition.status|capitalize }}
                                </span>
                            </div>
                            
                            {% if existingApplication %}
                                <div class="alert alert-info mt-3">
                                    <h6>Your Application Status:</h6>
                                    <span class="badge {% if existingApplication.status == 'pending' %}bg-warning{% elseif existingApplication.status == 'approved' %}bg-success{% else %}bg-danger{% endif %}">
                                        {{ existingApplication.status|capitalize }}
                                    </span>
                                    {% if existingApplication.appliedAt %}
                                        <p class="mt-2 mb-0">
                                            <small>Applied on: {{ existingApplication.appliedAt|date('M d, Y') }}</small>
                                        </p>
                                    {% endif %}
                                    {% if existingApplication.notes %}
                                        <p class="mt-2 mb-0">
                                            <small>Your notes: {{ existingApplication.notes }}</small>
                                        </p>
                                    {% endif %}
                                    
                                    {% if existingApplication.status == 'pending' %}
                                        <div class="mt-3">
                                            <a href="{{ path('app_athlete_application_withdraw', {'id': existingApplication.id}) }}" 
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Are you sure you want to withdraw your application?')">
                                                <i class="fas fa-times"></i> Withdraw Application
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                            {% else %}
                                {% if competition.status == 'upcoming' and not competition.isFull() %}
                                    <div class="card mt-3">
                                        <div class="card-body">
                                            <h6>Apply for this Competition</h6>
                                            <form method="post" action="{{ path('app_athlete_competition_apply', {'id': competition.id}) }}">
                                                <div class="mb-3">
                                                    <label for="notes" class="form-label">Additional Notes (Optional)</label>
                                                    <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Any additional information you want to provide..."></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-success w-100" 
                                                        onclick="return confirm('Submit your application?')">
                                                    <i class="fas fa-paper-plane"></i> Submit Application
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                {% elseif competition.isFull() %}
                                    <div class="alert alert-warning mt-3">
                                        <i class="fas fa-exclamation-triangle"></i> This competition is full
                                    </div>
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-between">
                <a href="{{ path('app_athlete_competitions') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Competitions
                </a>
                <a href="{{ path('app_athlete_dashboard') }}" class="btn btn-primary-custom">
                    <i class="fas fa-home"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}