{% extends 'base.html.twig' %}

{% block title %}Available Competitions - Athlete Dashboard{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .competition-card {
        transition: transform 0.2s;
    }
    .competition-card:hover {
        transform: translateY(-5px);
    }
    .badge-upcoming { background-color: #ffc107; color: #000; }
    .badge-ongoing { background-color: #28a745; color: #fff; }
    .badge-completed { background-color: #6c757d; color: #fff; }
    .badge-cancelled { background-color: #dc3545; color: #fff; }
    .application-status {
        font-weight: bold;
    }
    .status-pending { color: #ffc107; }
    .status-approved { color: #28a745; }
    .status-rejected { color: #dc3545; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4" style="color: var(--primary-green);">Available Competitions</h1>
            
            {% if competitions is empty %}
                <div class="alert alert-info">
                    No competitions available at the moment.
                </div>
            {% else %}
                <div class="row">
                    {% for competition in competitions %}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card card-custom h-100 competition-card">
                            {% if competition.image %}
                                <img src="{{ asset('uploads/competitions/' ~ competition.image) }}" 
                                     class="card-img-top" 
                                     alt="{{ competition.name }}"
                                     style="height: 200px; object-fit: cover;">
                            {% else %}
                                <div class="bg-light d-flex align-items-center justify-content-center" 
                                     style="height: 200px;">
                                    <i class="fas fa-trophy fa-3x text-muted"></i>
                                </div>
                            {% endif %}
                            
                            <div class="card-body">
                                <h5 class="card-title">{{ competition.name }}</h5>
                                <p class="card-text text-muted small">
                                    <i class="fas fa-calendar"></i> 
                                    {{ competition.startDate|date('M d, Y H:i') }} - {{ competition.endDate|date('M d, Y H:i') }}
                                </p>
                                <p class="card-text">
                                    <i class="fas fa-map-marker-alt"></i> {{ competition.location }}
                                </p>
                                <p class="card-text">
                                    <i class="fas fa-users"></i> 
                                    {{ competition.applications|length }}/{{ competition.maxParticipants }} participants
                                </p>
                                
                                <span class="badge badge-{{ competition.status }} mb-2">
                                    {{ competition.status|capitalize }}
                                </span>
                                
                                {% if applicationMap[competition.id] is defined %}
                                    <div class="mt-2">
                                        <span class="application-status status-{{ applicationMap[competition.id] }}">
                                            <i class="fas fa-info-circle"></i> 
                                            Your application: {{ applicationMap[competition.id]|capitalize }}
                                        </span>
                                    </div>
                                {% endif %}
                                
                                {% if competition.isFull() %}
                                    <div class="alert alert-warning mt-2 p-2">
                                        <small><i class="fas fa-exclamation-triangle"></i> This competition is full</small>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="card-footer bg-transparent">
                                <div class="d-flex justify-content-between">
                                    <a href="{{ path('app_athlete_competition_view', {'id': competition.id}) }}" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i> View Details
                                    </a>
                                    
                                    {% if applicationMap[competition.id] is not defined %}
                                        {% if competition.status == 'upcoming' and not competition.isFull() %}
                                            <a href="{{ path('app_athlete_competition_apply', {'id': competition.id}) }}" 
                                               class="btn btn-sm btn-success"
                                               onclick="return confirm('Apply for this competition?')">
                                                <i class="fas fa-paper-plane"></i> Apply
                                            </a>
                                        {% endif %}
                                    {% else %}
                                        {% if applicationMap[competition.id] == 'pending' %}
                                            <a href="{{ path('app_athlete_application_withdraw', {'id': userApplications|filter(a => a.competition.id == competition.id)|first.id}) }}" 
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Withdraw your application?')">
                                                <i class="fas fa-times"></i> Withdraw
                                            </a>
                                        {% endif %}
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% endif %}
            
            <div class="mt-4">
                <a href="{{ path('app_athlete_my_applications') }}" class="btn btn-primary-custom">
                    <i class="fas fa-list"></i> View My Applications
                </a>
                <a href="{{ path('app_athlete_dashboard') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}